        <circle cx="260" cy="85" r="5" fill="#7B3BA8" opacity="0.25"/>
        <circle cx="172" cy="125" r="6" fill="#5E2585" opacity="0.35"/>
        <circle cx="228" cy="125" r="6" fill="#7B3BA8" opacity="0.3"/>
        <circle cx="185" cy="205" r="5" fill="#A06AC4" opacity="0.3"/>
