<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HPV Cancers Alliance — Preventing HPV-Related Cancers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
  /*
    ROBIN HOOD DESIGN LANGUAGE adapted for HPVCA:
    - Bold oversized sans-serif headlines (Outfit 800/900)
    - Contrasting serif italic for editorial secondary heads (Instrument Serif)
    - Full-bleed hero sections with large type
    - Dynamic color: purple guides action, lavender for atmosphere
    - Story-forward editorial card grid
    - Big stat callouts (Robin Hood's "$3B" pattern)
    - Clean alternating sections, generous white space
    - Bottom triple CTA cards
    - Minimal navigation, prominent Donate
  */

  :root {
    /* HPVCA Brand */
    --purple-deep: #3A1057;
    --purple: #5E2585;
    --purple-mid: #7B3BA8;
    --purple-light: #A06AC4;
    --lavender: #C9A4E2;
    --lavender-soft: #E8D5F5;
    --lavender-bg: #F5EEFB;
    --lavender-faint: #FAF7FD;

    /* Neutrals */
    --white: #FFFFFF;
    --gray-50: #FAFAFB;
    --gray-100: #F4F3F6;
    --gray-200: #E8E6EC;
    --gray-300: #D0CDD6;
    --gray-400: #9E99A7;
    --gray-500: #6E6878;
    --gray-700: #3D3748;
    --gray-900: #1A1522;
    --black: #0E0A14;

    /* Accent */
    --green-accent: #4ADE80;

    /* Fonts - Robin Hood pattern: bold sans + contrasting serif */
    --sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    --serif: 'Instrument Serif', Georgia, serif;

    /* System */
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --radius: 0px; /* Robin Hood uses sharp corners */
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    color: var(--gray-900);
    background: var(--white);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  a { text-decoration: none; color: inherit; }

  /* ===========================
     NAV — Robin Hood style: minimal, logo left, links + donate right
     =========================== */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 40px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }
  .nav.scrolled {
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--gray-200);
  }
  .nav-logo {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--white);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: var(--transition);
  }
  .nav.scrolled .nav-logo { color: var(--gray-900); }
  .nav-logo-mark {
    width: 32px;
    height: 32px;
    background: var(--purple);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 900;
    font-size: 0.85rem;
  }
  .nav-links { display: flex; align-items: center; gap: 4px; }
  .nav-links a {
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255,255,255,0.75);
    padding: 8px 16px;
    border-radius: 6px;
    transition: var(--transition);
  }
  .nav-links a:hover { color: white; background: rgba(255,255,255,0.1); }
  .nav.scrolled .nav-links a { color: var(--gray-500); }
  .nav.scrolled .nav-links a:hover { color: var(--gray-900); background: var(--gray-100); }
  .nav-donate {
    background: var(--purple) !important;
    color: white !important;
    font-weight: 600 !important;
    padding: 10px 24px !important;
    border-radius: 50px !important;
    margin-left: 8px;
  }
  .nav-donate:hover { background: var(--purple-deep) !important; }
  .mobile-nav { display: none; background: none; border: none; cursor: pointer; padding: 6px; }
  .mobile-nav svg { width: 24px; height: 24px; }
  .mobile-nav .bar { fill: white; transition: var(--transition); }
  .nav.scrolled .mobile-nav .bar { fill: var(--gray-900); }

  /* ===========================
     HERO — Robin Hood: full-bleed, massive type, video/gradient bg
     =========================== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding: 0 40px 80px;
    position: relative;
    overflow: hidden;
    background: var(--black);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(14,10,20,0.2) 0%, rgba(14,10,20,0.55) 50%, rgba(14,10,20,0.92) 100%),
      linear-gradient(135deg, var(--purple-deep) 0%, var(--purple) 30%, var(--purple-mid) 60%, var(--lavender) 100%);
    background-size: cover;
  }
  /* Animated gradient orbs for atmosphere */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: float 12s ease-in-out infinite;
  }
  .hero-orb-1 {
    width: 500px; height: 500px;
    background: var(--purple);
    top: 10%; left: -5%;
    animation-delay: 0s;
  }
  .hero-orb-2 {
    width: 400px; height: 400px;
    background: var(--lavender);
    top: 30%; right: 5%;
    animation-delay: -4s;
  }
  .hero-orb-3 {
    width: 300px; height: 300px;
    background: var(--purple-mid);
    bottom: 10%; left: 40%;
    animation-delay: -8s;
  }
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 15px) scale(0.95); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    color: white;
  }
  .hero h1 {
    font-family: var(--sans);
    font-size: clamp(3.2rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
    text-transform: uppercase;
  }
  .hero-subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.55;
    color: rgba(255,255,255,0.75);
    max-width: 600px;
    margin-bottom: 40px;
    font-weight: 400;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--white);
    color: var(--purple-deep);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1rem;
    padding: 16px 32px;
    border-radius: 0;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    letter-spacing: 0.01em;
  }
  .hero-cta:hover { background: var(--lavender-soft); transform: translateY(-2px); }
  .hero-cta svg { width: 18px; height: 18px; transition: var(--transition); }
  .hero-cta:hover svg { transform: translateX(3px); }

  /* ===========================
     NEWS / EDITORIAL CARDS — Robin Hood pattern
     =========================== */
  .news-section {
    padding: 100px 40px 80px;
    background: var(--white);
  }
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--purple);
    margin-bottom: 8px;
  }
  .section-h2 {
    font-family: var(--sans);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--gray-900);
    text-transform: uppercase;
  }
  .section-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--purple);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: var(--transition);
    white-space: nowrap;
  }
  .section-link:hover { gap: 10px; }
  .section-link::after { content: '→'; }

  .news-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .news-card {
    background: var(--gray-50);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }
  .news-card:hover { background: var(--lavender-bg); }
  .news-card:hover .news-img img { transform: scale(1.03); }
  .news-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
  }
  .news-img {
    overflow: hidden;
    aspect-ratio: 16/10;
    background: var(--lavender-soft);
    position: relative;
  }
  .news-card.featured .news-img { aspect-ratio: auto; min-height: 380px; }
  .news-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  /* Placeholder images with purple gradient */
  .news-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--purple-light);
  }
  .news-body { padding: 32px; display: flex; flex-direction: column; justify-content: center; }
  .news-card.featured .news-body { padding: 44px; }
  .news-tag {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--purple);
    margin-bottom: 12px;
  }
  .news-title {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1.35;
    color: var(--gray-900);
    font-weight: 400;
  }
  .news-card.featured .news-title { font-size: 1.7rem; }

  /* ===========================
     BIG STATS — Robin Hood's "$3B" pattern
     =========================== */
  .stats-section {
    padding: 100px 40px;
    background: var(--purple-deep);
    color: white;
    position: relative;
    overflow: hidden;
  }
  .stats-section::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(160,106,196,0.2), transparent 70%);
    border-radius: 50%;
  }
  .stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .stats-intro {
    max-width: 650px;
    margin-bottom: 64px;
  }
  .stats-intro .section-label { color: var(--lavender); }
  .stats-intro h2 {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 400;
    line-height: 1.45;
    color: rgba(255,255,255,0.8);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .stat-item { border-top: 1px solid rgba(255,255,255,0.12); padding-top: 28px; }
  .stat-number {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 8px;
  }
  .stat-big {
    font-family: var(--sans);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: white;
  }
  .stat-suffix {
    font-family: var(--sans);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 800;
    color: var(--lavender);
  }
  .stat-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
  }

  /* ===========================
     TOOL FEATURE — editorial split (Robin Hood's program pattern)
     =========================== */
  .feature-section {
    padding: 0;
    background: var(--white);
  }
  .feature-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }
  .feature-visual {
    background: linear-gradient(160deg, var(--lavender-bg) 0%, var(--lavender-soft) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px;
    position: relative;
    overflow: hidden;
  }
  .feature-visual::before {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--lavender) 0%, transparent 70%);
    border-radius: 50%;
    opacity: 0.3;
    top: 20%;
    left: -10%;
  }
  .feature-mockup {
    background: var(--white);
    padding: 36px;
    width: 100%;
    max-width: 360px;
    box-shadow: 0 20px 60px rgba(58,16,87,0.12);
    position: relative;
    z-index: 1;
  }
  .feature-mockup-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--gray-200);
  }
  .feature-mockup-icon {
    width: 44px;
    height: 44px;
    background: var(--purple);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    font-weight: 800;
  }
  .feature-mockup-label { font-weight: 700; font-size: 1rem; color: var(--gray-900); }
  .feature-mockup-sub { font-size: 0.78rem; color: var(--gray-400); }
  .mock-row {
    background: var(--gray-100);
    padding: 14px 18px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.88rem;
  }
  .mock-row-label { color: var(--gray-400); }
  .mock-row-val { color: var(--purple); font-weight: 600; }
  .mock-submit {
    width: 100%;
    background: var(--purple);
    color: white;
    border: none;
    padding: 15px;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.92rem;
    margin-top: 10px;
    cursor: pointer;
    transition: var(--transition);
    letter-spacing: 0.02em;
  }
  .mock-submit:hover { background: var(--purple-deep); }

  .feature-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
  }
  .feature-text .section-label { margin-bottom: 12px; }
  .feature-text h2 {
    font-family: var(--sans);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--gray-900);
    margin-bottom: 20px;
  }
  .feature-text p {
    font-size: 1rem;
    color: var(--gray-500);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 440px;
  }
  .feature-steps {
    list-style: none;
    margin-bottom: 36px;
  }
  .feature-steps li {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 0;
    font-size: 0.92rem;
    color: var(--gray-700);
    border-bottom: 1px solid var(--gray-200);
  }
  .feature-steps li:last-child { border-bottom: none; }
  .step-n {
    width: 28px;
    height: 28px;
    min-width: 28px;
    background: var(--purple);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .btn-rh {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--purple);
    color: white;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 15px 30px;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    letter-spacing: 0.01em;
  }
  .btn-rh:hover { background: var(--purple-deep); }
  .btn-rh svg { width: 16px; height: 16px; transition: var(--transition); }
  .btn-rh:hover svg { transform: translateX(3px); }

  /* ===========================
     SURVIVOR / QUOTE — Robin Hood storytelling block
     =========================== */
  .story-section {
    padding: 100px 40px;
    background: var(--gray-50);
  }
  .story-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: start;
  }
  .story-quote-col {}
  .story-mark {
    font-family: var(--serif);
    font-size: 8rem;
    line-height: 0.7;
    color: var(--lavender);
    margin-bottom: 12px;
  }
  .story-avatar-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    min-width: 120px;
  }
  .story-av {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, var(--purple-light), var(--lavender));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 800;
    font-size: 1.5rem;
  }
  .story-av-name {
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--gray-900);
    text-align: center;
  }
  .story-av-role {
    font-size: 0.78rem;
    color: var(--gray-400);
    text-align: center;
    line-height: 1.3;
  }
  .story-blockquote {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    line-height: 1.5;
    color: var(--gray-900);
    margin-bottom: 28px;
  }
  .story-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: var(--purple);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  .story-cta:hover { gap: 12px; }
  .story-cta::after { content: '→'; }

  /* ===========================
     DONATE BANNER — Robin Hood "100% of your donation" pattern
     =========================== */
  .donate-section {
    background: var(--purple);
    padding: 64px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .donate-inner {
    max-width: 800px;
    text-align: center;
    color: white;
  }
  .donate-inner h2 {
    font-family: var(--sans);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    line-height: 1.05;
  }
  .donate-inner p {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
    line-height: 1.5;
  }
  .btn-white-rh {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--white);
    color: var(--purple-deep);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1rem;
    padding: 16px 36px;
    border: none;
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-white-rh:hover { background: var(--lavender-faint); transform: translateY(-2px); }

  /* ===========================
     TRIPLE CTA — Robin Hood bottom cards
     =========================== */
  .triple-cta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--white);
  }
  .triple-card {
    padding: 48px 40px;
    border-right: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    transition: var(--transition);
    cursor: pointer;
  }
  .triple-card:last-child { border-right: none; }
  .triple-card:hover { background: var(--lavender-bg); }
  .triple-card h3 {
    font-family: var(--sans);
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--gray-900);
  }
  .triple-arrow {
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: var(--purple);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
    transition: var(--transition);
  }
  .triple-card:hover .triple-arrow { background: var(--purple-deep); transform: translateX(3px); }

  /* ===========================
     FOOTER — Robin Hood clean footer
     =========================== */
  footer {
    background: var(--black);
    color: white;
    padding: 60px 40px 32px;
  }
  .footer-top {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-brand {
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .footer-tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.92rem;
    opacity: 0.45;
    line-height: 1.55;
    margin-bottom: 24px;
  }
  .footer-social { display: flex; gap: 8px; }
  .footer-social a {
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-size: 0.82rem;
    transition: var(--transition);
  }
  .footer-social a:hover { background: var(--purple); color: white; }
  .footer-col h4 {
