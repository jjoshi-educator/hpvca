        <path d="M200 60 L320 120 L320 240 Q320 320 200 360 Q80 320 80 240 L80 120 Z" fill="url(#s1)" opacity="0.08" stroke="#5E2585" stroke-width="1.5" opacity="0.15"/>
        <path d="M200 85 L300 135 L300 235 Q300 300 200 335 Q100 300 100 235 L100 135 Z" fill="url(#s2)" opacity="0.06"/>
        <!-- Cellular defense — immune cells surrounding -->
        <circle cx="200" cy="200" r="50" stroke="#7B3BA8" stroke-width="1" stroke-dasharray="4 4" opacity="0.2"/>
        <!-- Antibody Y-shapes -->
        <g opacity="0.35">
          <path d="M180 170 L190 185 L200 170" stroke="#5E2585" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <line x1="190" y1="185" x2="190" y2="205" stroke="#5E2585" stroke-width="2.5" stroke-linecap="round"/>
        </g>
        <g opacity="0.3" transform="translate(30, 20)">
          <path d="M180 170 L190 185 L200 170" stroke="#7B3BA8" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <line x1="190" y1="185" x2="190" y2="205" stroke="#7B3BA8" stroke-width="2.5" stroke-linecap="round"/>
        </g>
        <g opacity="0.25" transform="translate(-15, 35)">
          <path d="M180 170 L190 185 L200 170" stroke="#A06AC4" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <line x1="190" y1="185" x2="190" y2="205" stroke="#A06AC4" stroke-width="2.5" stroke-linecap="round"/>
        </g>
        <!-- Checkmark in center -->
        <path d="M182 200 L195 215 L225 180" stroke="#5E2585" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
        <!-- Blocked virus particles (faded, outside shield) -->
        <circle cx="60" cy="100" r="12" stroke="#C9A4E2" stroke-width="1" stroke-dasharray="2 2" opacity="0.2"/>
        <line x1="52" y1="92" x2="68" y2="108" stroke="#C9A4E2" stroke-width="1" opacity="0.2"/>
        <circle cx="340" cy="300" r="10" stroke="#C9A4E2" stroke-width="1" stroke-dasharray="2 2" opacity="0.15"/>
        <line x1="333" y1="293" x2="347" y2="307" stroke="#C9A4E2" stroke-width="1" opacity="0.15"/>
        <circle cx="350" cy="90" r="8" stroke="#E8D5F5" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.15"/>
        <!-- Soft radial glow -->
        <circle cx="200" cy="200" r="100" fill="url(#s3)" opacity="0.06"/>
        <defs>
          <linearGradient id="s1" x1="200" y1="60" x2="200" y2="360"><stop offset="0%" stop-color="#5E2585"/><stop offset="100%" stop-color="#C9A4E2"/></linearGradient>
          <linearGradient id="s2" x1="200" y1="85" x2="200" y2="335"><stop offset="0%" stop-color="#E8D5F5"/><stop offset="100%" stop-color="#F5EEFB" stop-opacity="0"/></linearGradient>
          <radialGradient id="s3"><stop offset="0%" stop-color="#5E2585"/><stop offset="100%" stop-color="#5E2585" stop-opacity="0"/></radialGradient>
        </defs>
      </svg>
    </div>
    <div class="card-info">
      <div class="use">Card Graphic / Prevention Section</div>
      <h3>Vaccine Protection (Shield + Antibodies)</h3>
      <p>Shield form with antibody Y-shapes inside, blocked virus particles outside. Communicates protection without being literal. Use for vaccination/prevention cards and campaign materials.</p>
    </div>
  </div>

  <!-- 4. SCREENING / DETECTION — Magnifying molecular view -->
  <div class="card">
    <div class="card-visual mid" style="padding: 40px;">
      <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Magnifying lens frame -->
        <circle cx="180" cy="180" r="110" stroke="white" stroke-width="2" opacity="0.2"/>
