<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HPV Cancers Alliance — Preventing HPV-Related Cancers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
  /*
    DESIGN SYSTEM:
    - Bold editorial hierarchy (Robin Hood pattern)
    - Organic pharmaceutical-style illustrations for science sections
      (soft cellular shapes, molecular bonds, radial gradients — 
       inspired by modern biopharma visual language)
    - HPVCA purple/lavender brand palette
    - White-clean foundation, sans-serif primary
    - Founders featured immediately after hero
    
    PHOTOGRAPHY DIRECTION:
    Photo Type 1: FOUNDERS — Warm editorial portraits, natural light, approachable
    Photo Type 2: COMMUNITY — Diverse groups, events, candid warmth
    Photo Type 3: SCIENCE — Clean labs, hopeful lighting, researchers at work
    Photo Type 4: SURVIVORS — Dignity-first, strength-forward portraits
    
    ILLUSTRATION DIRECTION:
    Organic abstract shapes representing cellular biology and molecular science.
    Soft gradients in purple/lavender. Flowing lines, not rigid geometric patterns.
    Think: cell membranes, DNA abstracted, protein structures as soft forms.
    Used for backgrounds, section accents, and decorative texture.
    Conveys: life science, hope, innovation, care.
  */

  :root {
    --purple-deep: #3A1057;
    --purple: #5E2585;
    --purple-mid: #7B3BA8;
    --purple-light: #A06AC4;
    --lavender: #C9A4E2;
    --lavender-soft: #E8D5F5;
    --lavender-bg: #F5EEFB;
    --lavender-faint: #FAF7FD;
    --white: #FFFFFF;
    --gray-50: #FAFAFB;
    --gray-100: #F4F3F6;
    --gray-200: #E8E6EC;
    --gray-300: #D0CDD6;
    --gray-400: #9E99A7;
    --gray-500: #6E6878;
    --gray-700: #3D3748;
    --gray-900: #1A1522;
    --black: #0E0A14;
    --sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    --serif: 'Instrument Serif', Georgia, serif;
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); color: var(--gray-900); background: var(--white); line-height: 1.55; -webkit-font-smoothing: antialiased; }
  a { text-decoration: none; color: inherit; }
  img { display: block; max-width: 100%; }

  /* === NAV === */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 40px; height: 72px; display: flex; align-items: center; justify-content: space-between; transition: background 0.4s, box-shadow 0.4s; }
  .nav.scrolled { background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); box-shadow: 0 1px 0 var(--gray-200); }
  .nav-logo { display: flex; align-items: center; gap: 0; transition: var(--transition); }
  .nav-logo img { height: 44px; width: auto; filter: brightness(0) invert(1); transition: var(--transition); }
  .nav.scrolled .nav-logo img { filter: none; }
  .nav-links { display: flex; align-items: center; gap: 4px; }
  .nav-links a { font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.75); padding: 8px 16px; border-radius: 6px; transition: var(--transition); }
  .nav-links a:hover { color: white; background: rgba(255,255,255,0.1); }
  .nav.scrolled .nav-links a { color: var(--gray-500); }
  .nav.scrolled .nav-links a:hover { color: var(--gray-900); background: var(--gray-100); }
  .nav-donate { background: var(--purple) !important; color: white !important; font-weight: 600 !important; padding: 10px 24px !important; border-radius: 50px !important; margin-left: 8px; }
  .nav-donate:hover { background: var(--purple-deep) !important; }
  .mobile-toggle { display: none; background: none; border: none; cursor: pointer; padding: 6px; }
  .mobile-toggle svg { width: 24px; height: 24px; }
  .mobile-toggle rect { fill: white; transition: var(--transition); }
  .nav.scrolled .mobile-toggle rect { fill: var(--gray-900); }

  /* === HERO === */
  .hero { min-height: 100vh; display: flex; align-items: flex-end; padding: 0 40px 80px; position: relative; overflow: hidden; background: var(--black); }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg svg { position: absolute; width: 100%; height: 100%; }
  .hero-gradient { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(14,10,20,0.15) 0%, rgba(14,10,20,0.5) 40%, rgba(14,10,20,0.88) 100%); z-index: 1; }
  /* Optional: hero background photo */
  .hero-photo-bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: url('https://hpvca.org/wp-content/uploads/2025/08/hpv_alliance_cover.jpeg');
    background-size: cover;
    background-position: center 30%;
    mix-blend-mode: luminosity;
    opacity: 0.35;
  }
  .hero-content { position: relative; z-index: 2; max-width: 850px; color: white; }
  .hero h1 { font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 900; line-height: 0.95; letter-spacing: -0.04em; margin-bottom: 24px; text-transform: uppercase; }
  .hero-sub { font-family: var(--serif); font-style: italic; font-size: clamp(1.1rem, 1.8vw, 1.4rem); line-height: 1.55; color: rgba(255,255,255,0.7); max-width: 580px; margin-bottom: 36px; }
  .hero-cta { display: inline-flex; align-items: center; gap: 10px; background: var(--white); color: var(--purple-deep); font-family: var(--sans); font-weight: 700; font-size: 1rem; padding: 16px 32px; border: none; cursor: pointer; transition: var(--transition); }
  .hero-cta:hover { background: var(--lavender-soft); transform: translateY(-2px); }
  .hero-cta svg { width: 16px; height: 16px; transition: var(--transition); }
  .hero-cta:hover svg { transform: translateX(3px); }

  /* === FOUNDERS === */
  .founders-section { padding: 0; background: var(--white); }
  .founders-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .founder-card { display: grid; grid-template-columns: 1fr 1fr; min-height: 460px; }
  .founder-card:nth-child(2) .founder-photo { order: 2; }
  .founder-card:nth-child(2) .founder-text { order: 1; }
  .founder-photo {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, var(--lavender-soft) 0%, var(--lavender-bg) 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .founder-photo svg.organic-bg { position: absolute; width: 100%; height: 100%; opacity: 0.08; }
  /* Actual founder images */
  .founder-photo img.founder-img {
    width: 200px; height: 200px;
    border-radius: 50%;
    object-fit: cover;
    position: relative; z-index: 1;
    box-shadow: 0 12px 40px rgba(58,16,87,0.15);
  }
  .founder-text { display: flex; flex-direction: column; justify-content: center; padding: 48px 44px; }
  .founder-role { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--purple); margin-bottom: 12px; }
  .founder-name { font-size: clamp(1.5rem, 2.5vw, 2.1rem); font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase; line-height: 1.05; margin-bottom: 6px; color: var(--gray-900); }
  .founder-title { font-family: var(--serif); font-style: italic; font-size: 1rem; color: var(--gray-400); margin-bottom: 16px; }
  .founder-bio { font-size: 0.92rem; color: var(--gray-500); line-height: 1.65; margin-bottom: 20px; }
  .founder-link { display: inline-flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.88rem; color: var(--purple); transition: var(--transition); }
  .founder-link:hover { gap: 10px; }
  .founder-link::after { content: '→'; }

  /* === SCIENCE SECTION === */
  .science-section { padding: 100px 40px; background: var(--gray-50); position: relative; overflow: hidden; }
  .science-section .bio-illustration { position: absolute; top: 0; right: 0; width: 50%; height: 100%; opacity: 0.04; pointer-events: none; }
  .science-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .science-header { max-width: 600px; margin-bottom: 52px; }
  .section-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--purple); margin-bottom: 10px; }
  .section-h2 { font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 900; line-height: 1; letter-spacing: -0.03em; text-transform: uppercase; color: var(--gray-900); margin-bottom: 14px; }
  .section-sub { font-family: var(--serif); font-style: italic; font-size: 1.05rem; color: var(--gray-400); line-height: 1.55; }
  .science-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .science-card { background: var(--white); padding: 36px 30px; border: 1px solid var(--gray-200); transition: var(--transition); position: relative; overflow: hidden; }
  .science-card:hover { border-color: var(--lavender); box-shadow: 0 8px 30px rgba(94,37,133,0.08); transform: translateY(-3px); }
  .science-card .card-accent { position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; opacity: 0.06; }
  .science-card-icon { width: 52px; height: 52px; background: var(--lavender-bg); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
  .science-card-icon .icon-inner { font-size: 1.4rem; }
  .science-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
  .science-card p { font-size: 0.88rem; color: var(--gray-500); line-height: 1.65; margin-bottom: 14px; }
  .card-link { display: inline-flex; align-items: center; gap: 5px; color: var(--purple); font-weight: 600; font-size: 0.84rem; transition: var(--transition); }
  .card-link:hover { gap: 9px; }
  .card-link::after { content: '→'; }

  /* === STATS === */
  .stats-section { padding: 100px 40px; background: var(--purple-deep); color: white; position: relative; overflow: hidden; }
  .stats-bg { position: absolute; inset: 0; opacity: 0.06; pointer-events: none; }
  .stats-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .stats-intro { max-width: 600px; margin-bottom: 60px; }
  .stats-intro .section-label { color: var(--lavender); }
  .stats-intro h2 { font-family: var(--serif); font-style: italic; font-size: clamp(1.3rem, 2.2vw, 1.8rem); font-weight: 400; line-height: 1.5; color: rgba(255,255,255,0.75); }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .stat-item { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; }
  .stat-big { font-size: clamp(3.5rem, 6vw, 5.5rem); font-weight: 900; line-height: 1; letter-spacing: -0.04em; }
  .stat-suffix { font-size: clamp(1.5rem, 2.5vw, 2.2rem); font-weight: 800; color: var(--lavender); }
  .stat-desc { font-size: 0.92rem; color: rgba(255,255,255,0.5); line-height: 1.5; margin-top: 8px; }

  /* === HPV NEXT STEPS TOOL === */
  .tool-section { padding: 0; background: var(--white); }
  .tool-split { display: grid; grid-template-columns: 1fr 1fr; min-height: 560px; }
  .tool-visual { background: var(--lavender-bg); display: flex; align-items: center; justify-content: center; padding: 60px; position: relative; overflow: hidden; }
  .tool-visual .cell-bg { position: absolute; width: 100%; height: 100%; opacity: 0.07; pointer-events: none; }
  .tool-mockup { background: var(--white); padding: 36px; width: 100%; max-width: 360px; box-shadow: 0 20px 60px rgba(58,16,87,0.12); position: relative; z-index: 1; }
  .tool-mockup-head { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--gray-200); }
  /* HPV Next Steps logo */
  .tool-mockup-logo { height: 36px; width: auto; }
  .tool-mockup-icon { width: 44px; height: 44px; background: var(--purple); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.2rem; font-weight: 800; }
  .tool-mockup-label { font-weight: 700; font-size: 1rem; }
  .tool-mockup-sub { font-size: 0.78rem; color: var(--gray-400); }
  .mock-row { background: var(--gray-100); padding: 14px 18px; margin-bottom: 8px; display: flex; justify-content: space-between; font-size: 0.88rem; }
  .mock-row-label { color: var(--gray-400); }
  .mock-row-val { color: var(--purple); font-weight: 600; }
  .mock-submit { width: 100%; background: var(--purple); color: white; border: none; padding: 15px; font-family: var(--sans); font-weight: 700; font-size: 0.92rem; margin-top: 10px; cursor: pointer; transition: var(--transition); }
  .mock-submit:hover { background: var(--purple-deep); }
  .tool-text { display: flex; flex-direction: column; justify-content: center; padding: 80px 60px; }
  .tool-text p { font-size: 0.95rem; color: var(--gray-500); line-height: 1.7; margin-bottom: 24px; max-width: 440px; }
  .tool-steps { list-style: none; margin-bottom: 32px; }
  .tool-steps li { display: flex; align-items: center; gap: 14px; padding: 11px 0; font-size: 0.9rem; color: var(--gray-700); border-bottom: 1px solid var(--gray-200); }
  .tool-steps li:last-child { border-bottom: none; }
  .step-n { width: 28px; height: 28px; min-width: 28px; background: var(--purple); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 700; }
  .btn-rh { display: inline-flex; align-items: center; gap: 10px; background: var(--purple); color: white; font-family: var(--sans); font-weight: 700; font-size: 0.95rem; padding: 15px 30px; border: none; cursor: pointer; transition: var(--transition); }
  .btn-rh:hover { background: var(--purple-deep); }
  .btn-rh svg { width: 16px; height: 16px; }

  /* === SURVIVOR STORY === */
  .story-section { padding: 100px 40px; background: var(--white); }
  .story-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: auto 1fr; gap: 48px; align-items: start; }
  .story-av-block { display: flex; flex-direction: column; align-items: center; gap: 10px; min-width: 120px; }
  .story-av { width: 96px; height: 96px; border-radius: 50%; object-fit: cover; box-shadow: 0 8px 24px rgba(58,16,87,0.12); }
  .story-av-name { font-weight: 700; font-size: 0.85rem; text-align: center; }
  .story-av-role { font-size: 0.75rem; color: var(--gray-400); text-align: center; line-height: 1.3; }
  .story-mark { font-family: var(--serif); font-size: 6rem; line-height: 0.7; color: var(--lavender); margin-bottom: 8px; }
  .story-quote { font-family: var(--serif); font-style: italic; font-size: clamp(1.2rem, 2vw, 1.65rem); line-height: 1.5; color: var(--gray-900); margin-bottom: 24px; }
  .story-link { display: inline-flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.88rem; color: var(--purple); transition: var(--transition); }
  .story-link:hover { gap: 10px; }
  .story-link::after { content: '→'; }

  /* === NEWS === */
  .news-section { padding: 100px 40px 80px; background: var(--gray-50); }
  .news-header { display: flex; align-items: flex-end; justify-content: space-between; max-width: 1200px; margin: 0 auto 44px; }
  .news-link { font-size: 0.88rem; font-weight: 600; color: var(--purple); display: flex; align-items: center; gap: 6px; transition: var(--transition); white-space: nowrap; }
  .news-link:hover { gap: 10px; }
  .news-link::after { content: '→'; }
  .news-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .news-card { background: var(--white); overflow: hidden; transition: var(--transition); cursor: pointer; }
  .news-card:hover { box-shadow: 0 8px 30px rgba(94,37,133,0.07); }
  .news-card.featured { grid-column: 1 / -1; display: grid; grid-template-columns: 1.1fr 0.9fr; }
  .news-img { overflow: hidden; aspect-ratio: 16/10; position: relative; background: var(--lavender-bg); }
  .news-card.featured .news-img { aspect-ratio: auto; min-height: 360px; }
  .news-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .news-card:hover .news-img img { transform: scale(1.03); }
  .news-img-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
  .news-body { padding: 30px; display: flex; flex-direction: column; justify-content: center; }
  .news-card.featured .news-body { padding: 44px; }
  .news-tag { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--purple); margin-bottom: 10px; }
  .news-title { font-family: var(--serif); font-style: italic; font-size: 1.2rem; line-height: 1.35; color: var(--gray-900); }
  .news-card.featured .news-title { font-size: 1.6rem; }

  /* === DONATE === */
  .donate-section { background: var(--purple); padding: 64px 40px; text-align: center; position: relative; overflow: hidden; }
  .donate-deco { position: absolute; inset: 0; opacity: 0.06; pointer-events: none; }
  .donate-inner { position: relative; z-index: 1; color: white; max-width: 700px; margin: 0 auto; }
  .donate-inner h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 900; text-transform: uppercase; letter-spacing: -0.03em; margin-bottom: 12px; line-height: 1.05; }
  .donate-inner p { font-family: var(--serif); font-style: italic; font-size: 1.05rem; color: rgba(255,255,255,0.65); margin-bottom: 28px; }
  .btn-white { display: inline-flex; align-items: center; gap: 10px; background: white; color: var(--purple-deep); font-family: var(--sans); font-weight: 700; font-size: 1rem; padding: 16px 36px; border: none; cursor: pointer; transition: var(--transition); }
  .btn-white:hover { background: var(--lavender-faint); transform: translateY(-2px); }

  /* === TRIPLE CTA === */
  .triple-cta { display: grid; grid-template-columns: repeat(3, 1fr); }
  .triple-card { padding: 44px 36px; border-right: 1px solid var(--gray-200); display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: var(--transition); cursor: pointer; background: var(--white); }
  .triple-card:last-child { border-right: none; }
  .triple-card:hover { background: var(--lavender-bg); }
  .triple-card h3 { font-size: 1.05rem; font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; }
  .triple-arrow { width: 38px; height: 38px; min-width: 38px; background: var(--purple); display: flex; align-items: center; justify-content: center; color: white; font-size: 1rem; transition: var(--transition); }
  .triple-card:hover .triple-arrow { background: var(--purple-deep); transform: translateX(3px); }

  /* === FOOTER === */
  footer { background: var(--black); color: white; padding: 56px 40px 28px; }
  .footer-top { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 44px; margin-bottom: 44px; }
  .footer-logo { margin-bottom: 14px; }
  .footer-logo img { height: 48px; width: auto; filter: brightness(0) invert(1); opacity: 0.7; }
  .footer-tagline { font-family: var(--serif); font-style: italic; font-size: 0.9rem; opacity: 0.4; line-height: 1.5; margin-bottom: 20px; }
  .footer-social { display: flex; gap: 8px; }
  .footer-social a { width: 34px; height: 34px; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); font-size: 0.8rem; transition: var(--transition); }
  .footer-social a:hover { background: var(--purple); color: white; }
  .footer-col h4 { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; opacity: 0.3; font-weight: 700; margin-bottom: 14px; }
  .footer-col a { display: block; font-size: 0.86rem; opacity: 0.5; margin-bottom: 9px; transition: var(--transition); }
  .footer-col a:hover { opacity: 1; }
  .footer-nl { max-width: 1200px; margin: 0 auto; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .footer-nl-text { font-family: var(--serif); font-style: italic; font-size: 0.95rem; opacity: 0.55; }
  .footer-nl-form { display: flex; gap: 0; }
  .footer-nl-input { padding: 11px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: white; font-family: var(--sans); font-size: 0.86rem; outline: none; width: 240px; transition: var(--transition); }
  .footer-nl-input::placeholder { color: rgba(255,255,255,0.2); }
  .footer-nl-input:focus { border-color: var(--purple-light); }
  .footer-nl-btn { background: var(--purple); color: white; border: none; padding: 11px 20px; font-family: var(--sans); font-weight: 700; font-size: 0.84rem; cursor: pointer; }
  .footer-bottom { max-width: 1200px; margin: 28px auto 0; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; font-size: 0.74rem; opacity: 0.22; flex-wrap: wrap; gap: 10px; }
  .footer-bottom a { color: white; text-decoration: underline; text-underline-offset: 2px; }
  .footer-guidestar { display: flex; align-items: center; gap: 12px; margin-top: 16px; }
  .footer-guidestar img { height: 44px; width: auto; opacity: 0.5; }

  /* === PHOTO DIRECTION PANEL === */
  .photo-panel { position: fixed; bottom: 24px; right: 24px; z-index: 200; display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .photo-toggle { background: var(--gray-900); color: white; border: none; padding: 12px 20px; border-radius: 50px; font-family: var(--sans); font-size: 0.82rem; font-weight: 600; cursor: pointer; box-shadow: 0 4px 20px rgba(0,0,0,0.25); transition: var(--transition); display: flex; align-items: center; gap: 6px; }
  .photo-toggle:hover { transform: translateY(-2px); }
  .photo-notes { display: none; background: var(--gray-900); color: white; padding: 24px; border-radius: 12px; width: 380px; max-height: 70vh; overflow-y: auto; box-shadow: 0 12px 40px rgba(0,0,0,0.3); font-size: 0.82rem; line-height: 1.55; }
  .photo-notes.open { display: block; }
  .photo-notes h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 16px; color: var(--lavender); }
  .photo-notes h5 { font-size: 0.82rem; font-weight: 700; color: var(--purple-light); margin-top: 14px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.06em; }
  .photo-notes p { opacity: 0.7; margin-bottom: 8px; }
  .photo-notes .ref { color: var(--lavender-soft); opacity: 0.5; font-style: italic; font-size: 0.78rem; }

