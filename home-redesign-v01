<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPV Cancers Alliance - Education, Prevention, Action</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            /* HPVCA Brand Colors - Purple/Lavender Primary */
            --purple: #7B5BA6;
            --purple-dark: #5C4080;
            --purple-deep: #4A3366;
            --purple-light: #E8E0F0;
            --lavender: #B8A5D3;
            --lavender-light: #F3EFF8;
            --coral: #F4A27F;
            --coral-dark: #E8845A;
            --coral-light: #FDE8DC;
            --peach: #FFEEE5;
            --teal: #00A5A8;
            --teal-light: #D4F1F1;
            --navy: #2D3E50;
            --charcoal: #1A2530;
            --warm-gray: #F9F7FC;
            --white: #FFFFFF;
            
            /* Typography - Clean Sans-Serif */
            --font-display: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-body: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
            
            /* Spacing */
            --space-xs: 8px;
            --space-sm: 16px;
            --space-md: 24px;
            --space-lg: 48px;
            --space-xl: 80px;
            --space-2xl: 120px;
            
            /* Transitions */
            --transition-fast: 0.2s ease;
            --transition-medium: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-slow: 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            color: var(--navy);
            line-height: 1.6;
            background: var(--white);
            overflow-x: hidden;
        }

        /* Skip Link - Accessibility */
        .skip-link {
            position: absolute;
            top: -100px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--purple-dark);
            color: white;
            padding: 12px 24px;
            border-radius: 0 0 8px 8px;
            z-index: 10000;
            transition: top var(--transition-fast);
        }

        .skip-link:focus {
            top: 0;
            outline: 3px solid var(--coral);
            outline-offset: 2px;
        }

        /* ==================== HEADER ==================== */
        header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(123, 91, 166, 0.1);
            transition: all var(--transition-medium);
        }

        header.scrolled {
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
        }

        .header-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 var(--space-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 80px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: var(--navy);
        }

        .logo-mark {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--purple) 0%, var(--purple-dark) 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .logo-mark::before {
            content: '';
            position: absolute;
            width: 24px;
            height: 24px;
            border: 3px solid white;
            border-radius: 50%;
            opacity: 0.9;
        }

        .logo-mark::after {
            content: '';
            position: absolute;
            width: 8px;
            height: 8px;
            background: var(--coral);
            border-radius: 50%;
            top: 12px;
            right: 12px;
        }

        .logo-text {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 20px;
            letter-spacing: -0.02em;
        }

        .logo-text span {
            color: var(--purple);
        }

        nav {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
        }

        .nav-link {
            font-size: 15px;
            font-weight: 500;
            color: var(--navy);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            transition: all var(--transition-fast);
            position: relative;
        }

        .nav-link:hover {
            color: var(--purple-dark);
            background: var(--purple-light);
        }

        .nav-link:focus-visible {
            outline: 2px solid var(--purple);
            outline-offset: 2px;
        }

        .nav-link.has-dropdown::after {
            content: '';
            width: 0;
            height: 0;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-top: 5px solid currentColor;
            margin-left: 6px;
            display: inline-block;
            vertical-align: middle;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: var(--font-body);
            font-size: 15px;
            font-weight: 600;
            padding: 12px 28px;
            border-radius: 100px;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all var(--transition-fast);
            position: relative;
            overflow: hidden;
        }

        .btn:focus-visible {
            outline: 3px solid var(--coral);
            outline-offset: 3px;
        }

        .btn-primary {
            background: var(--purple);
            color: white;
        }

        .btn-primary:hover {
            background: var(--purple-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(123, 91, 166, 0.35);
        }

        .btn-secondary {
            background: transparent;
            color: var(--purple-dark);
            border: 2px solid var(--purple);
        }

        .btn-secondary:hover {
            background: var(--purple);
            color: white;
        }

        .btn-coral {
            background: var(--coral);
            color: var(--charcoal);
        }

        .btn-coral:hover {
            background: var(--coral-dark);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(244, 162, 127, 0.4);
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            width: 44px;
            height: 44px;
            cursor: pointer;
            position: relative;
        }

        .mobile-menu-btn span {
            display: block;
            width: 24px;
            height: 2px;
            background: var(--navy);
            position: absolute;
            left: 10px;
            transition: all var(--transition-fast);
        }

        .mobile-menu-btn span:nth-child(1) { top: 15px; }
        .mobile-menu-btn span:nth-child(2) { top: 21px; }
        .mobile-menu-btn span:nth-child(3) { top: 27px; }

        /* ==================== HERO ==================== */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            background: linear-gradient(165deg, var(--white) 0%, var(--lavender-light) 50%, var(--warm-gray) 100%);
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            overflow: hidden;
        }

        .hero-shape {
            position: absolute;
            border-radius: 50%;
            opacity: 0.4;
            animation: float 20s ease-in-out infinite;
        }

        .hero-shape-1 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, var(--purple-light) 0%, transparent 70%);
            top: -200px;
            right: -100px;
        }

        .hero-shape-2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, var(--coral-light) 0%, transparent 70%);
            bottom: -100px;
            left: -100px;
            animation-delay: -10s;
        }

        .hero-shape-3 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, var(--lavender) 0%, transparent 70%);
            top: 50%;
            left: 60%;
            animation-delay: -5s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -30px) scale(1.05); }
            66% { transform: translate(-20px, 20px) scale(0.95); }
        }

        .hero-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: var(--space-2xl) var(--space-md);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-xl);
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .hero-text {
            animation: fadeSlideUp 1s ease forwards;
        }

        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 14px;
            font-weight: 600;
            color: var(--purple-dark);
            margin-bottom: var(--space-md);
            box-shadow: 0 4px 20px rgba(123, 91, 166, 0.15);
            animation: fadeSlideUp 1s ease 0.2s both;
        }

        .hero-badge::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--coral);
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
        }

        .hero h1 {
            font-family: var(--font-display);
            font-size: clamp(42px, 6vw, 72px);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -0.02em;
            color: var(--charcoal);
            margin-bottom: var(--space-md);
            animation: fadeSlideUp 1s ease 0.3s both;
        }

        .hero h1 em {
            font-style: normal;
            font-weight: 700;
            color: var(--purple);
        }

        .hero-subtitle {
            font-size: 20px;
            line-height: 1.7;
            color: var(--navy);
            margin-bottom: var(--space-lg);
            max-width: 540px;
            animation: fadeSlideUp 1s ease 0.4s both;
        }

        .hero-ctas {
            display: flex;
            gap: var(--space-sm);
            flex-wrap: wrap;
            animation: fadeSlideUp 1s ease 0.5s both;
        }

        .hero-visual {
            position: relative;
            animation: fadeSlideUp 1s ease 0.4s both;
        }

        .hero-card {
            background: white;
            border-radius: 24px;
            padding: var(--space-lg);
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }

        .hero-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--purple), var(--lavender), var(--coral));
        }

        .hero-stat {
            text-align: center;
            padding: var(--space-md);
        }

        .hero-stat-number {
            font-family: var(--font-display);
            font-size: 64px;
            font-weight: 700;
            color: var(--purple);
            line-height: 1;
            margin-bottom: 8px;
        }

        .hero-stat-label {
            font-size: 16px;
            color: var(--navy);
            font-weight: 500;
        }

        .hero-stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--space-sm);
            margin-top: var(--space-md);
            padding-top: var(--space-md);
            border-top: 1px solid rgba(123, 91, 166, 0.1);
        }

        .mini-stat {
            text-align: center;
        }

        .mini-stat-number {
            font-family: var(--font-display);
            font-size: 28px;
            font-weight: 700;
            color: var(--charcoal);
        }

        .mini-stat-label {
            font-size: 13px;
            color: var(--navy);
            opacity: 0.8;
        }

        /* Floating elements around hero card */
        .float-element {
            position: absolute;
            background: white;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            animation: floatElement 6s ease-in-out infinite;
        }

        .float-element-1 {
            top: -30px;
            right: -30px;
            animation-delay: -2s;
        }

        .float-element-2 {
            bottom: 60px;
            left: -40px;
            animation-delay: -4s;
        }

        @keyframes floatElement {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        .float-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .float-icon.teal { background: var(--purple-light); }
        .float-icon.coral { background: var(--coral-light); }

        /* ==================== MARQUEE ==================== */
        .marquee-section {
            background: var(--purple-dark);
            padding: var(--space-sm) 0;
            overflow: hidden;
        }

        .marquee {
            display: flex;
            animation: marquee 30s linear infinite;
        }

        .marquee-content {
            display: flex;
            align-items: center;
            gap: var(--space-lg);
            padding: 0 var(--space-lg);
            white-space: nowrap;
        }

        .marquee-item {
            font-family: var(--font-body);
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: white;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .marquee-item::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--coral);
            border-radius: 50%;
        }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* ==================== MISSION SECTION ==================== */
        .mission {
            padding: var(--space-2xl) var(--space-md);
            background: var(--white);
        }

        .mission-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: var(--space-xl);
            align-items: center;
        }

        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--purple);
            margin-bottom: var(--space-sm);
        }

        .section-label::before {
            content: '';
            width: 24px;
            height: 2px;
            background: var(--purple);
        }

        .mission h2 {
            font-family: var(--font-display);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 600;
            line-height: 1.2;
            color: var(--charcoal);
            margin-bottom: var(--space-md);
        }

        .mission h2 em {
            font-style: normal;
            font-weight: 700;
            color: var(--purple);
        }

        .mission p {
            font-size: 18px;
            line-height: 1.8;
            color: var(--navy);
            margin-bottom: var(--space-md);
        }

        .mission-visual {
            position: relative;
        }

        .mission-image-wrapper {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            aspect-ratio: 4/3;
            background: linear-gradient(135deg, var(--purple-light), var(--lavender-light));
        }

        .mission-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .mission-image-wrapper::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 60%, rgba(92, 64, 128, 0.3));
        }

        .founders-badge {
            position: absolute;
            bottom: -30px;
            right: 30px;
            background: white;
            border-radius: 16px;
            padding: var(--space-md);
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12);
            display: flex;
            align-items: center;
            gap: var(--space-sm);
        }

        .founders-avatars {
            display: flex;
        }

        .founder-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 3px solid white;
            background: var(--purple-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: var(--purple-dark);
            font-size: 14px;
        }

        .founder-avatar:not(:first-child) {
            margin-left: -12px;
        }

        .founders-info {
            font-size: 14px;
        }

        .founders-info strong {
            display: block;
            color: var(--charcoal);
        }

        .founders-info span {
            color: var(--navy);
            opacity: 0.7;
        }

        /* ==================== PREVENTION PILLARS ==================== */
        .pillars {
            padding: var(--space-2xl) var(--space-md);
            background: var(--warm-gray);
            position: relative;
            overflow: hidden;
        }

        .pillars::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--purple), transparent);
        }

        .pillars-inner {
            max-width: 1200px;
            margin: 0 auto;
        }

        .pillars-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto var(--space-xl);
        }

        .pillars h2 {
            font-family: var(--font-display);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 600;
            color: var(--charcoal);
            margin-bottom: var(--space-sm);
        }

        .pillars-subtitle {
            font-size: 18px;
            color: var(--navy);
        }

        .pillars-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-md);
        }

        .pillar-card {
            background: white;
            border-radius: 20px;
            padding: var(--space-lg);
            position: relative;
            overflow: hidden;
            transition: all var(--transition-medium);
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .pillar-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            transition: height var(--transition-medium);
        }

        .pillar-card:nth-child(1)::before { background: var(--purple); }
        .pillar-card:nth-child(2)::before { background: var(--lavender); }
        .pillar-card:nth-child(3)::before { background: var(--coral); }

        .pillar-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 60px rgba(123, 91, 166, 0.15);
        }

        .pillar-card:hover::before {
            height: 6px;
        }

        .pillar-card:focus-visible {
            outline: 3px solid var(--purple);
            outline-offset: 4px;
        }

        .pillar-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: var(--space-md);
        }

        .pillar-card:nth-child(1) .pillar-icon { background: var(--purple-light); }
        .pillar-card:nth-child(2) .pillar-icon { background: var(--lavender-light); }
        .pillar-card:nth-child(3) .pillar-icon { background: var(--coral-light); }

        .pillar-card h3 {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 600;
            color: var(--charcoal);
            margin-bottom: var(--space-sm);
        }

        .pillar-card p {
            font-size: 15px;
            color: var(--navy);
            line-height: 1.7;
            margin-bottom: var(--space-md);
        }

        .pillar-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            font-size: 15px;
            transition: gap var(--transition-fast);
        }

        .pillar-card:nth-child(1) .pillar-link { color: var(--purple-dark); }
        .pillar-card:nth-child(2) .pillar-link { color: var(--purple); }
        .pillar-card:nth-child(3) .pillar-link { color: var(--coral-dark); }

        .pillar-card:hover .pillar-link {
            gap: 12px;
        }

        .pillar-link svg {
            width: 20px;
            height: 20px;
            transition: transform var(--transition-fast);
        }

        .pillar-card:hover .pillar-link svg {
            transform: translateX(4px);
        }

        /* ==================== NEWS & RESOURCES ==================== */
        .news {
            padding: var(--space-2xl) var(--space-md);
            background: var(--white);
        }

        .news-inner {
            max-width: 1200px;
            margin: 0 auto;
        }

        .news-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: var(--space-lg);
        }

        .news h2 {
            font-family: var(--font-display);
            font-size: clamp(32px, 4vw, 42px);
            font-weight: 600;
            color: var(--charcoal);
        }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-md);
        }

        .news-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(123, 91, 166, 0.1);
            transition: all var(--transition-medium);
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .news-card:hover {
            border-color: var(--purple);
            box-shadow: 0 20px 50px rgba(123, 91, 166, 0.15);
            transform: translateY(-4px);
        }

        .news-card:focus-visible {
            outline: 3px solid var(--purple);
            outline-offset: 2px;
        }

        .news-image {
            aspect-ratio: 16/10;
            background: linear-gradient(135deg, var(--purple-light), var(--lavender-light));
            position: relative;
            overflow: hidden;
        }

        .news-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform var(--transition-medium);
        }

        .news-card:hover .news-image img {
            transform: scale(1.05);
        }

        .news-tag {
            position: absolute;
            top: 16px;
            left: 16px;
            background: white;
            padding: 6px 12px;
