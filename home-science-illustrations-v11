        <circle cx="200" cy="330" r="18" fill="url(#n2)" opacity="0.2"/>
        <circle cx="200" cy="310" r="8" fill="url(#n2)" opacity="0.25"/>
        <!-- Connection lines -->
        <line x1="200" y1="190" x2="100" y2="140" stroke="#C9A4E2" stroke-width="1" opacity="0.2"/>
        <line x1="200" y1="190" x2="300" y2="140" stroke="#C9A4E2" stroke-width="1" opacity="0.2"/>
        <line x1="200" y1="190" x2="120" y2="280" stroke="#C9A4E2" stroke-width="1" opacity="0.15"/>
        <line x1="200" y1="190" x2="280" y2="280" stroke="#C9A4E2" stroke-width="1" opacity="0.15"/>
        <line x1="200" y1="190" x2="200" y2="330" stroke="#C9A4E2" stroke-width="1" opacity="0.12"/>
        <line x1="100" y1="140" x2="120" y2="280" stroke="#A06AC4" stroke-width="0.5" opacity="0.1"/>
        <line x1="300" y1="140" x2="280" y2="280" stroke="#A06AC4" stroke-width="0.5" opacity="0.1"/>
