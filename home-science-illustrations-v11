        <circle cx="310" cy="300" r="5" fill="#E8D5F5" opacity="0.15"/>
        <circle cx="60" cy="100" r="4" fill="#C9A4E2" opacity="0.12"/>
      </svg>
    </div>
    <div class="card-info">
      <div class="use">Section Art / Research Pages</div>
      <h3>DNA Double Helix</h3>
      <p>Flowing organic helix with base-pair rungs and nucleotide dots. Not rigid/mechanical — uses curves and varying opacity for a living, breathing quality. Use for research, genomics, or "emerging science" content.</p>
    </div>
  </div>

  <!-- 6. CONNECTED COMMUNITY — Network/support -->
  <div class="card">
    <div class="card-visual dark" style="padding: 40px;">
      <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Human-shaped nodes — abstracted as circles with smaller head circles -->
