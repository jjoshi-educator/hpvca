<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPVCA Design System - Visual Reference</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --teal: #00A5A8;
            --deep-teal: #007B7D;
            --coral: #F4A27F;
            --coral-deep: #E8845A;
            --purple: #7B5BA6;
            --purple-deep: #5C4080;
            --navy: #2D3E50;
            --charcoal: #1A2530;
            --slate: #5A6A7A;
            --cool-gray: #E8EAEC;
            --warm-gray: #F7F5F3;
            --teal-light: #D4F1F1;
            --aqua: #5BC9CA;
            --peach-light: #FDE8DC;
            --coral-light: #F8C8B8;
            --lavender-light: #E8E0F0;
            --violet: #9B7BC4;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--warm-gray);
            color: var(--navy);
            line-height: 1.6;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
        }
        
        header {
            background: linear-gradient(135deg, var(--deep-teal), var(--teal));
            color: white;
            padding: 60px 24px;
            text-align: center;
        }
        
        header h1 {
            font-weight: 300;
            font-size: 48px;
            margin-bottom: 16px;
        }
        
        header p {
            font-size: 18px;
            opacity: 0.9;
        }
        
        section {
            background: white;
            border-radius: 12px;
            padding: 40px;
            margin-bottom: 32px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }
        
        h2 {
            font-weight: 300;
            font-size: 32px;
            color: var(--deep-teal);
            margin-bottom: 32px;
            padding-bottom: 16px;
            border-bottom: 2px solid var(--teal-light);
        }
        
        h3 {
            font-weight: 600;
            font-size: 18px;
            color: var(--navy);
            margin: 24px 0 16px;
        }
        
        /* Color Palette Styles */
        .color-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }
        
        .color-swatch {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .color-preview {
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }
        
        .color-info {
            padding: 16px;
            background: white;
        }
        
        .color-name {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
        }
        
        .color-hex {
            font-family: monospace;
            font-size: 13px;
            color: var(--slate);
        }
        
        /* Typography Styles */
        .type-sample {
            margin-bottom: 24px;
            padding: 24px;
            background: var(--warm-gray);
            border-radius: 8px;
        }
        
        .type-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--teal);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        .h1-sample { font-size: 54px; font-weight: 300; line-height: 1.07; }
        .h2-sample { font-size: 42px; font-weight: 300; line-height: 1.1; }
        .h3-sample { font-size: 32px; font-weight: 300; line-height: 1.25; }
        .h4-sample { font-size: 24px; font-weight: 400; line-height: 1.33; }
        .body-sample { font-size: 16px; font-weight: 400; line-height: 1.5; }
        
        /* Button Styles */
        .button-row {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 24px;
        }
        
        .btn {
            padding: 12px 24px;
            border-radius: 24px;
            font-family: inherit;
            font-size: 16px;
            font-weight: 400;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-primary {
            background: var(--teal);
            color: white;
            border: 1px solid var(--teal);
        }
        
        .btn-primary:hover {
            background: white;
            color: var(--teal);
        }
        
        .btn-secondary {
            background: transparent;
            color: var(--teal);
            border: 1px solid var(--teal);
        }
        
        .btn-secondary:hover {
            background: var(--teal-light);
        }
        
        .btn-accent {
            background: var(--coral);
            color: var(--charcoal);
            border: 1px solid var(--coral);
        }
        
        .btn-accent:hover {
            background: var(--coral-deep);
            border-color: var(--coral-deep);
            color: white;
        }
        
        .btn-purple {
            background: var(--purple);
            color: white;
            border: 1px solid var(--purple);
        }
        
        .btn-purple:hover {
            background: var(--purple-deep);
            border-color: var(--purple-deep);
        }
        
        /* Illustration Styles */
        .illustration-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 32px;
        }
        
        .illustration-card {
            background: var(--warm-gray);
            border-radius: 12px;
            overflow: hidden;
        }
        
        .illustration-preview {
            height: 250px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .illustration-info {
            padding: 24px;
        }
        
        .illustration-title {
            font-weight: 600;
            font-size: 20px;
            margin-bottom: 8px;
            color: var(--deep-teal);
        }
        
        .illustration-desc {
            font-size: 14px;
            color: var(--slate);
            margin-bottom: 16px;
        }
        
        .tag {
            display: inline-block;
            padding: 4px 12px;
            background: var(--teal-light);
            color: var(--deep-teal);
            border-radius: 16px;
            font-size: 12px;
            font-weight: 600;
            margin-right: 8px;
            margin-bottom: 8px;
        }
        
        /* Geometric Line Art Style */
        .style-geometric {
            background: linear-gradient(135deg, var(--teal-light), white);
        }
        
        .geometric-illustration {
            position: relative;
            width: 200px;
            height: 200px;
        }
        
        .geo-circle {
            position: absolute;
            border: 3px solid var(--deep-teal);
            border-radius: 50%;
        }
        
        .geo-circle-1 {
            width: 120px;
            height: 120px;
            top: 20px;
            left: 10px;
        }
        
        .geo-circle-2 {
            width: 80px;
            height: 80px;
            top: 50px;
            left: 80px;
            border-color: var(--coral);
        }
        
        .geo-circle-3 {
            width: 100px;
            height: 100px;
            top: 80px;
            left: 40px;
            border-color: var(--teal);
        }
        
        .geo-line {
            position: absolute;
            height: 3px;
            background: var(--aqua);
            transform-origin: left center;
        }
        
        .geo-line-1 {
            width: 60px;
            top: 80px;
            left: 70px;
            transform: rotate(-30deg);
        }
        
        .geo-line-2 {
            width: 80px;
            top: 130px;
            left: 30px;
            transform: rotate(15deg);
            background: var(--coral);
        }
        
        /* Blob Style */
        .style-blob {
            background: linear-gradient(180deg, #FFF 0%, var(--warm-gray) 100%);
            overflow: hidden;
        }
        
        .blob-container {
            position: relative;
            width: 220px;
            height: 220px;
        }
        
        .blob {
            position: absolute;
            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            animation: blob-morph 8s ease-in-out infinite;
        }
        
        .blob-1 {
            width: 150px;
            height: 150px;
            background: linear-gradient(135deg, var(--teal-light), var(--aqua));
            opacity: 0.7;
            top: 20px;
            left: 10px;
        }
        
        .blob-2 {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--peach-light), var(--coral));
            opacity: 0.8;
            top: 80px;
            left: 90px;
            animation-delay: -4s;
        }
        
        .blob-3 {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--lavender-light), var(--purple));
            opacity: 0.6;
            top: 110px;
            left: 30px;
            animation-delay: -2s;
        }
        
        @keyframes blob-morph {
            0%, 100% {
                border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            }
            50% {
                border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
            }
        }
        
        /* Component Preview */
        .component-preview {
            background: var(--warm-gray);
            padding: 32px;
            border-radius: 12px;
            margin-bottom: 24px;
        }
        
        .card-demo {
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 24px;
            max-width: 320px;
            transition: all 0.2s ease;
        }
        
        .card-demo:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
            transform: translateY(-2px);
        }
        
        .card-tag {
            font-size: 12px;
            font-weight: 600;
            color: var(--teal);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .card-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--navy);
        }
        
        .card-text {
            font-size: 14px;
            color: var(--slate);
            margin-bottom: 16px;
        }
        
        .card-link {
            color: var(--teal);
            text-decoration: none;
            font-weight: 600;
        }
        
        .card-link:hover {
            text-decoration: underline;
        }
        
        /* Form Elements */
        .form-group {
            margin-bottom: 20px;
            max-width: 400px;
        }
        
        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 8px;
        }
        
        .form-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--cool-gray);
            border-radius: 4px;
            font-family: inherit;
            font-size: 16px;
            transition: all 0.2s ease;
        }
        
        .form-input:focus {
            outline: none;
            border-color: var(--teal);
            box-shadow: 0 0 0 3px var(--teal-light);
        }
        
        .form-helper {
            font-size: 13px;
            color: var(--slate);
            margin-top: 6px;
        }
        
        /* Accessibility Note */
        .a11y-note {
            background: var(--teal-light);
            border-left: 4px solid var(--teal);
            padding: 16px 20px;
            border-radius: 0 8px 8px 0;
            margin: 24px 0;
        }
        
        .a11y-note strong {
            color: var(--deep-teal);
        }
        
        /* Footer */
        footer {
            text-align: center;
            padding: 40px;
            color: var(--slate);
            font-size: 14px;
        }
    </style>
</head>
<body>
    <header>
        <h1>HPVCA Design System</h1>
        <p>Visual Reference Guide for Digital Products</p>
    </header>
    
