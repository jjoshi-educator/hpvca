        <line x1="258" y1="258" x2="340" y2="340" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.2"/>
        <!-- Inside the lens — revealed cellular detail -->
        <circle cx="180" cy="180" r="100" fill="white" opacity="0.05"/>
        <!-- Cells visible through the lens -->
        <ellipse cx="150" cy="160" rx="40" ry="35" stroke="white" stroke-width="1" opacity="0.3"/>
        <circle cx="150" cy="155" r="10" fill="white" opacity="0.1"/>
        <ellipse cx="210" cy="200" rx="35" ry="30" stroke="white" stroke-width="1" opacity="0.25"/>
        <circle cx="210" cy="195" r="8" fill="white" opacity="0.08"/>
        <ellipse cx="170" cy="220" rx="28" ry="25" stroke="white" stroke-width="0.8" opacity="0.2"/>
        <!-- Highlighted cell (detected) -->
        <ellipse cx="200" cy="150" rx="25" ry="22" stroke="#E8D5F5" stroke-width="2" opacity="0.5"/>
        <circle cx="200" cy="148" r="7" fill="#E8D5F5" opacity="0.3"/>
        <!-- Pulse rings around detected cell -->
        <circle cx="200" cy="150" r="32" stroke="#E8D5F5" stroke-width="0.8" opacity="0.2"/>
        <circle cx="200" cy="150" r="42" stroke="#E8D5F5" stroke-width="0.5" opacity="0.1"/>
        <!-- Outside lens — abstract blur -->
        <circle cx="50" cy="80" r="20" fill="white" opacity="0.04"/>
        <circle cx="340" cy="120" r="15" fill="white" opacity="0.03"/>
        <circle cx="80" cy="320" r="25" fill="white" opacity="0.03"/>
      </svg>
    </div>
    <div class="card-info">
      <div class="use">Card Graphic / Screening Section</div>
      <h3>Screening &amp; Early Detection</h3>
      <p>Magnifying lens revealing cellular detail with a highlighted detected cell. Communicates precision, early detection, and care. Use for screening guidelines or diagnostic content.</p>
    </div>
  </div>

  <!-- 5. DNA / MOLECULAR HELIX -->
