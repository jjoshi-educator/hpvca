<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPV Cancers Alliance</title>
    <style>
        @page {
            size: 11in 72in;
            margin: 0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background: #FFFFFF;
            color: #1A2530;
            width: 11in;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        
        a {
            text-decoration: none;
            color: inherit;
        }
        
        /* ==================== HEADER ==================== */
        .utility-bar {
            background: #5C4080;
            padding: 10px 80px;
            display: flex;
            justify-content: flex-end;
            gap: 32px;
            font-size: 13px;
        }
        
        .utility-bar a {
            color: rgba(255,255,255,0.85);
        }
        
        .utility-bar a:hover {
            color: white;
        }
        
        .utility-bar .highlight {
            color: #FFEEE5;
            font-weight: 600;
        }
        
        .header {
            padding: 20px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            border-bottom: 1px solid #E8E0F0;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }
        
        .logo-mark {
            width: 44px;
            height: 44px;
            background: #7B5BA6;
            border-radius: 10px;
            position: relative;
            flex-shrink: 0;
        }
        
        .logo-mark::before {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            border: 2.5px solid white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        
        .logo-text {
            font-size: 20px;
            font-weight: 700;
            color: #1A2530;
            white-space: nowrap;
        }
        
        .logo-text span {
            color: #7B5BA6;
        }
        
        .main-nav {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }
        
        .nav-link {
            font-size: 15px;
            color: #2D3E50;
            font-weight: 500;
            padding: 8px 0;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
            white-space: nowrap;
        }
        
        .nav-link:hover {
            color: #7B5BA6;
            border-bottom-color: #7B5BA6;
        }
        
        .nav-actions {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-left: 16px;
            padding-left: 24px;
            border-left: 1px solid #E8E0F0;
        }
        
        .nav-cta {
            background: #7B5BA6;
            color: white;
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
            white-space: nowrap;
        }
        
        .nav-cta:hover {
            background: #5C4080;
        }
        
        .nav-donate {
            color: #5C4080;
            font-weight: 600;
            font-size: 14px;
            white-space: nowrap;
        }
        
        .nav-donate:hover {
            color: #7B5BA6;
        }
        
        /* ==================== HERO ==================== */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 560px;
        }
        
        .hero-content {
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #FAFAFA;
        }
        
        .hero-eyebrow {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #7B5BA6;
            margin-bottom: 16px;
        }
        
        .hero h1 {
            font-size: 48px;
            font-weight: 700;
            line-height: 1.1;
            color: #1A2530;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        .hero-lead {
            font-size: 19px;
            line-height: 1.7;
            color: #4A5568;
            margin-bottom: 32px;
            max-width: 480px;
        }
        
        .hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #7B5BA6;
            color: white;
            padding: 16px 32px;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            transition: background 0.2s;
            width: fit-content;
        }
        
        .hero-cta:hover {
            background: #5C4080;
        }
        
        .hero-cta svg {
            width: 20px;
            height: 20px;
        }
        
        .hero-secondary {
            margin-top: 16px;
            color: #5C4080;
            font-size: 15px;
            font-weight: 500;
        }
        
        .hero-secondary:hover {
            text-decoration: underline;
        }
        
        .hero-image {
            background: linear-gradient(135deg, #E8E0F0 0%, #D4C8E5 100%);
        }
        
        /* ==================== IMPACT STATS ==================== */
        .impact-bar {
            background: #5C4080;
            padding: 48px 80px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 48px;
        }
        
        .impact-stat {
            text-align: center;
            color: white;
        }
        
        .impact-number {
            font-size: 48px;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 8px;
        }
        
        .impact-label {
            font-size: 14px;
            opacity: 0.85;
            line-height: 1.4;
        }
        
        /* ==================== MISSION ==================== */
        .mission {
            padding: 100px 80px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }
        
        .mission-content {
            max-width: 480px;
        }
        
        .section-eyebrow {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #7B5BA6;
            margin-bottom: 16px;
        }
        
        .mission h2 {
            font-size: 40px;
            font-weight: 700;
            line-height: 1.15;
            color: #1A2530;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        .mission p {
            font-size: 17px;
            line-height: 1.8;
            color: #4A5568;
            margin-bottom: 16px;
        }
        
        .mission-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #5C4080;
            font-size: 15px;
            font-weight: 600;
            margin-top: 16px;
        }
        
        .mission-link:hover {
            gap: 12px;
        }
        
        .mission-image {
            background: linear-gradient(135deg, #E8E0F0 0%, #F3EFF8 100%);
            border-radius: 16px;
            height: 400px;
        }
        
        /* ==================== WHAT IS HPV ==================== */
        .info-section {
            background: #F9F7FC;
            padding: 100px 80px;
        }
        
        .info-header {
            max-width: 600px;
            margin-bottom: 60px;
        }
        
        .info-header h2 {
            font-size: 40px;
            font-weight: 700;
            line-height: 1.15;
            color: #1A2530;
            margin-bottom: 16px;
            letter-spacing: -0.02em;
        }
        
        .info-header p {
            font-size: 18px;
            line-height: 1.7;
            color: #4A5568;
        }
        
        .cancer-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 20px;
            margin-bottom: 60px;
        }
        
        .cancer-card {
            background: white;
            border-radius: 12px;
            padding: 24px 20px;
            text-align: center;
            border: 1px solid #E8E0F0;
            transition: all 0.2s;
        }
        
        .cancer-card:hover {
            border-color: #7B5BA6;
            box-shadow: 0 8px 24px rgba(123, 91, 166, 0.1);
        }
        
        .cancer-bar {
            width: 6px;
            background: #7B5BA6;
            border-radius: 3px;
            margin: 0 auto 16px;
        }
        
        .cancer-card:nth-child(1) .cancer-bar { height: 60px; background: #5C4080; }
        .cancer-card:nth-child(2) .cancer-bar { height: 55px; background: #6D4D94; }
        .cancer-card:nth-child(3) .cancer-bar { height: 35px; background: #7B5BA6; }
        .cancer-card:nth-child(4) .cancer-bar { height: 22px; background: #9B7BC6; }
        .cancer-card:nth-child(5) .cancer-bar { height: 16px; background: #B8A5D3; }
        .cancer-card:nth-child(6) .cancer-bar { height: 12px; background: #D4C8E5; }
        
        .cancer-name {
            font-size: 14px;
            font-weight: 600;
            color: #1A2530;
            margin-bottom: 4px;
        }
        
        .cancer-stat {
            font-size: 12px;
            color: #6B7280;
        }
        
        .info-narrative {
            background: white;
            border-radius: 12px;
            padding: 40px;
            border-left: 4px solid #7B5BA6;
        }
        
        .info-narrative p {
            font-size: 18px;
            line-height: 1.8;
            color: #1A2530;
        }
        
        .info-narrative strong {
            color: #5C4080;
            font-weight: 600;
        }
        
        .info-source {
            margin-top: 16px;
            font-size: 13px;
            color: #6B7280;
        }
        
        /* ==================== QUESTIONS ==================== */
        .questions-section {
            padding: 100px 80px;
            background: white;
        }
        
        .questions-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 48px;
        }
        
        .questions-header h2 {
            font-size: 36px;
            font-weight: 700;
            color: #1A2530;
            letter-spacing: -0.02em;
        }
        
        .questions-header a {
            color: #5C4080;
            font-size: 15px;
            font-weight: 600;
        }
        
        .questions-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
        
        .question-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 24px 28px;
            background: #F9F7FC;
            border-radius: 8px;
            border: 1px solid transparent;
            transition: all 0.2s;
        }
        
        .question-card:hover {
            background: white;
            border-color: #7B5BA6;
            box-shadow: 0 4px 16px rgba(123, 91, 166, 0.1);
        }
        
        .question-text {
            font-size: 16px;
            font-weight: 500;
            color: #1A2530;
        }
        
        .question-arrow {
            color: #7B5BA6;
            font-size: 20px;
            transition: transform 0.2s;
        }
        
        .question-card:hover .question-arrow {
            transform: translateX(4px);
        }
        
        /* ==================== TOOL SECTION ==================== */
        .tool-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        
        .tool-content {
            background: #5C4080;
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
        }
        
        .tool-eyebrow {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.7);
            margin-bottom: 16px;
        }
        
        .tool-content h2 {
            font-size: 40px;
            font-weight: 700;
            line-height: 1.15;
            margin-bottom: 20px;
            letter-spacing: -0.02em;
        }
        
        .tool-content h2 em {
            font-style: normal;
            color: #FFEEE5;
        }
        
        .tool-content p {
            font-size: 18px;
            line-height: 1.7;
            opacity: 0.9;
            margin-bottom: 32px;
            max-width: 420px;
        }
        
        .tool-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: white;
            color: #5C4080;
            padding: 16px 32px;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            width: fit-content;
            transition: all 0.2s;
        }
        
        .tool-cta:hover {
            background: #FFEEE5;
        }
        
        .tool-visual {
            background: linear-gradient(135deg, #7B5BA6 0%, #9B7BC6 100%);
            padding: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .tool-preview {
            background: rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 360px;
        }
        
        .tool-preview-header {
            text-align: center;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            margin-bottom: 24px;
            color: white;
        }
        
        .tool-preview-header strong {
            display: block;
            font-size: 18px;
            margin-bottom: 4px;
        }
        
        .tool-preview-header span {
            font-size: 14px;
            opacity: 0.8;
        }
        
        .tool-steps {
            color: white;
        }
        
        .tool-step {
            display: flex;
            gap: 16px;
            margin-bottom: 20px;
        }
        
        .tool-step:last-child {
            margin-bottom: 0;
        }
        
        .step-num {
            width: 28px;
            height: 28px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }
        
        .step-text {
            font-size: 14px;
            line-height: 1.5;
            padding-top: 4px;
        }
        
        /* ==================== SURVIVOR STORY ==================== */
        .story-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        
        .story-image {
            background: linear-gradient(135deg, #D4C8E5 0%, #E8E0F0 100%);
            min-height: 480px;
        }
        
        .story-content {
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #FAFAFA;
        }
        
        .story-content .section-eyebrow {
            color: #E8845A;
        }
        
        .story-quote {
            font-size: 28px;
            font-weight: 600;
            line-height: 1.4;
            color: #1A2530;
            margin-bottom: 32px;
            letter-spacing: -0.01em;
        }
        
        .story-attribution {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }
        
        .attribution-avatar {
            width: 56px;
            height: 56px;
            background: #E8E0F0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 600;
            color: #5C4080;
        }
        
        .attribution-info strong {
            display: block;
            font-size: 16px;
            color: #1A2530;
            margin-bottom: 2px;
        }
        
        .attribution-info span {
            font-size: 14px;
            color: #6B7280;
        }
        
        .story-link {
            color: #5C4080;
            font-size: 15px;
            font-weight: 600;
        }
        
        .story-link:hover {
            text-decoration: underline;
        }
        
        /* ==================== FOUNDERS ==================== */
        .founders-section {
            padding: 100px 80px;
            background: white;
        }
        
        .founders-header {
            text-align: center;
            max-width: 600px;
            margin: 0 auto 60px;
        }
        
        .founders-header h2 {
            font-size: 40px;
            font-weight: 700;
            line-height: 1.15;
            color: #1A2530;
            margin-bottom: 16px;
            letter-spacing: -0.02em;
        }
        
        .founders-header p {
            font-size: 18px;
            line-height: 1.7;
            color: #4A5568;
        }
        
        .founders-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 32px;
            margin-bottom: 60px;
        }
        
        .founder-card {
            display: grid;
            grid-template-columns: 200px 1fr;
            background: #F9F7FC;
            border-radius: 16px;
            overflow: hidden;
        }
        
        .founder-image {
            background: linear-gradient(135deg, #D4C8E5 0%, #E8E0F0 100%);
        }
        
        .founder-info {
            padding: 32px;
        }
        
        .founder-name {
            font-size: 22px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 4px;
        }
        
        .founder-title {
            font-size: 14px;
            font-weight: 600;
            color: #7B5BA6;
            margin-bottom: 16px;
        }
        
        .founder-bio {
            font-size: 15px;
            line-height: 1.7;
            color: #4A5568;
        }
        
        .partners-section {
            background: #F9F7FC;
            border-radius: 12px;
            padding: 32px 40px;
            display: flex;
            align-items: center;
            gap: 40px;
        }
        
        .partners-label {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #5C4080;
            white-space: nowrap;
        }
        
        .partners-list {
            font-size: 14px;
            color: #4A5568;
            line-height: 1.8;
        }
        
        /* ==================== NEWS ==================== */
        .news-section {
            padding: 100px 80px;
            background: #FAFAFA;
        }
        
        .news-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 48px;
        }
        
        .news-header h2 {
            font-size: 36px;
            font-weight: 700;
            color: #1A2530;
            letter-spacing: -0.02em;
        }
        
        .news-header a {
            color: #5C4080;
            font-size: 15px;
            font-weight: 600;
        }
        
        .news-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
        }
        
        .news-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #E8E0F0;
            transition: all 0.2s;
        }
        
        .news-card:hover {
            border-color: #7B5BA6;
            box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        }
        
        .news-image {
            height: 180px;
            background: linear-gradient(135deg, #E8E0F0 0%, #F3EFF8 100%);
        }
        
        .news-card:nth-child(2) .news-image {
            background: linear-gradient(135deg, #FDE8DC 0%, #F3EFF8 100%);
        }
        
        .news-card:nth-child(3) .news-image {
            background: linear-gradient(135deg, #D4C8E5 0%, #E8E0F0 100%);
        }
        
        .news-content {
            padding: 24px;
        }
        
        .news-tag {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #7B5BA6;
            margin-bottom: 12px;
        }
        
        .news-card h3 {
            font-size: 20px;
            font-weight: 600;
            color: #1A2530;
            line-height: 1.3;
            margin-bottom: 8px;
        }
        
        .news-card p {
            font-size: 15px;
            color: #6B7280;
            line-height: 1.6;
        }
        
        /* ==================== CTA ==================== */
        .final-cta {
            padding: 100px 80px;
            background: linear-gradient(135deg, #F9F7FC 0%, #E8E0F0 100%);
            text-align: center;
        }
        
        .final-cta h2 {
            font-size: 40px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 16px;
            letter-spacing: -0.02em;
        }
        
        .final-cta p {
            font-size: 18px;
            color: #4A5568;
            margin-bottom: 36px;
            max-width: 480px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .cta-buttons {
            display: flex;
            justify-content: center;
            gap: 16px;
        }
        
        .btn {
            padding: 16px 32px;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .btn-primary {
            background: #F4A27F;
            color: #1A2530;
        }
        
        .btn-primary:hover {
            background: #E8845A;
        }
        
        .btn-secondary {
            background: white;
            color: #5C4080;
            border: 2px solid #7B5BA6;
        }
        
        .btn-secondary:hover {
            background: #7B5BA6;
            color: white;
        }
        
        /* ==================== FOOTER ==================== */
        .footer {
            padding: 60px 80px 40px;
            background: #F9F7FC;
            border-top: 1px solid #E8E0F0;
        }
        
        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr repeat(4, 1fr);
            gap: 48px;
            margin-bottom: 48px;
        }
        
        .footer-brand p {
            font-size: 14px;
            color: #6B7280;
            margin-top: 16px;
            line-height: 1.7;
            max-width: 280px;
        }
        
        .footer-social {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }
        
        .social-link {
            width: 36px;
            height: 36px;
            background: #E8E0F0;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #5C4080;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .social-link:hover {
            background: #7B5BA6;
            color: white;
        }
        
        .footer-nav h4 {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #1A2530;
            margin-bottom: 20px;
        }
        
        .footer-nav ul {
            list-style: none;
        }
        
        .footer-nav li {
            margin-bottom: 12px;
        }
        
