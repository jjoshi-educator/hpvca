<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPVCA Website Redesign v4 - Visual Enhancement</title>
    <style>
        @page {
            size: 11in 85in;
            margin: 0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background: #FFFFFF;
            color: #1A2530;
            width: 11in;
            line-height: 1.7;
        }
        
        /* ==================== 
           ICON SYSTEM DEFINITION
           ==================== */
        
        .icon-system-guide {
            padding: 40px 60px;
            background: #F9F7FC;
            border-bottom: 1px solid #E8E0F0;
        }
        
        .icon-system-guide h2 {
            font-size: 24px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 8px;
        }
        
        .icon-system-guide > p {
            font-size: 14px;
            color: #5A6A7A;
            margin-bottom: 32px;
        }
        
        .icon-categories {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 32px;
        }
        
        .icon-category h3 {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #7B5BA6;
            margin-bottom: 16px;
            padding-bottom: 8px;
            border-bottom: 2px solid #E8E0F0;
        }
        
        .icon-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }
        
        .icon-sample {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            font-size: 18px;
        }
        
        .icon-sample.filled {
            background: #7B5BA6;
            color: white;
        }
        
        .icon-sample.outline {
            background: #F3EFF8;
            color: #5C4080;
        }
        
        .icon-sample.warm {
            background: #FDE8DC;
            color: #E8845A;
        }
        
        .icon-label {
            font-size: 13px;
            color: #2D3E50;
        }
        
        /* ==================== 
           HEADER
           ==================== */
        
        .crisis-bar {
            background: #5C4080;
            padding: 10px 60px;
            display: flex;
            justify-content: center;
            gap: 40px;
            font-size: 13px;
        }
        
        .crisis-bar a {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .crisis-bar a:first-child {
            font-weight: 600;
            color: #FFEEE5;
        }
        
        .header {
            padding: 16px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #E8E0F0;
            background: white;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        
        .logo-mark {
            width: 40px;
            height: 40px;
            background: #7B5BA6;
            border-radius: 8px;
            position: relative;
        }
        
        .logo-mark::before {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 2px solid white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        
        .logo-text {
            font-size: 18px;
            font-weight: 700;
            color: #1A2530;
        }
        
        .logo-text span {
            color: #7B5BA6;
        }
        
        .main-nav {
            display: flex;
            gap: 28px;
            align-items: center;
        }
        
        .nav-link {
            font-size: 14px;
            color: #2D3E50;
            text-decoration: none;
            padding: 8px 0;
            border-bottom: 2px solid transparent;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .nav-link:hover {
            color: #7B5BA6;
            border-bottom-color: #7B5BA6;
        }
        
        .nav-icon {
            font-size: 16px;
        }
        
        .nav-cta {
            background: #7B5BA6;
            color: white;
            padding: 10px 18px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .nav-donate {
            color: #E8845A;
            font-weight: 600;
            text-decoration: none;
            font-size: 14px;
        }
        
        /* ==================== 
           HERO WITH EDITORIAL PHOTOGRAPHY
           ==================== */
        
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 500px;
        }
        
        .hero-content {
            padding: 80px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .hero h1 {
            font-size: 44px;
            font-weight: 700;
            line-height: 1.15;
            color: #1A2530;
            margin-bottom: 20px;
        }
        
        .hero h1 .data {
            color: #7B5BA6;
        }
        
        .hero-lead {
            font-size: 19px;
            line-height: 1.7;
            color: #2D3E50;
            margin-bottom: 32px;
        }
        
        .hero-ctas {
            display: flex;
            gap: 16px;
            align-items: center;
        }
        
        .btn {
            padding: 14px 28px;
            border-radius: 4px;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: #7B5BA6;
            color: white;
        }
        
        .btn-secondary {
            color: #5C4080;
            text-decoration: underline;
        }
        
        /* PHOTO PLACEHOLDER */
        .hero-photo {
            background: linear-gradient(135deg, #E8E0F0 0%, #D4C8E5 100%);
            position: relative;
            overflow: hidden;
        }
        
        .photo-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px;
            text-align: center;
        }
        
        .photo-placeholder-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }
        
        .photo-direction {
            background: white;
            padding: 16px 24px;
            border-radius: 8px;
            max-width: 300px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        
        .photo-direction-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #7B5BA6;
            margin-bottom: 8px;
        }
        
        .photo-direction p {
            font-size: 13px;
            color: #2D3E50;
            line-height: 1.5;
        }
        
        /* ==================== 
           DATA VISUALIZATION SECTION
           ==================== */
        
        .data-section {
            padding: 60px;
            background: #FFFFFF;
            border-bottom: 1px solid #E8E0F0;
        }
        
        .data-section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
        }
        
        .data-section-header h2 {
            font-size: 28px;
            font-weight: 700;
            color: #1A2530;
        }
        
        .data-section-header p {
            font-size: 16px;
            color: #5A6A7A;
            max-width: 400px;
        }
        
        .data-source {
            font-size: 12px;
            color: #5A6A7A;
            text-align: right;
        }
        
        /* CHART 1: Cancer Types with Icons */
        .cancer-chart {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 16px;
            margin-bottom: 48px;
        }
        
        .cancer-type {
            text-align: center;
        }
        
        .cancer-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 12px;
            background: #F3EFF8;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            position: relative;
        }
        
        .cancer-bar-vertical {
            width: 8px;
            background: #7B5BA6;
            border-radius: 4px;
            margin: 0 auto 12px;
        }
        
        .cancer-type:nth-child(1) .cancer-bar-vertical { height: 80px; background: #5C4080; }
        .cancer-type:nth-child(2) .cancer-bar-vertical { height: 60px; background: #7B5BA6; }
        .cancer-type:nth-child(3) .cancer-bar-vertical { height: 40px; background: #9B7BC6; }
        .cancer-type:nth-child(4) .cancer-bar-vertical { height: 25px; background: #B8A5D3; }
        .cancer-type:nth-child(5) .cancer-bar-vertical { height: 20px; background: #D4C8E5; }
        .cancer-type:nth-child(6) .cancer-bar-vertical { height: 15px; background: #E8E0F0; }
        
        .cancer-name {
            font-size: 13px;
            font-weight: 600;
            color: #1A2530;
            margin-bottom: 4px;
        }
        
        .cancer-stat {
            font-size: 12px;
            color: #5A6A7A;
        }
        
        /* CHART 2: Timeline */
        .timeline-chart {
            background: #F9F7FC;
            border-radius: 8px;
            padding: 32px;
            margin-bottom: 48px;
        }
        
        .timeline-title {
            font-size: 16px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 24px;
        }
        
        .timeline {
            position: relative;
            display: flex;
            justify-content: space-between;
            padding: 0 20px;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            top: 24px;
            left: 40px;
            right: 40px;
            height: 4px;
            background: linear-gradient(90deg, #5C4080, #7B5BA6, #B8A5D3, #E8E0F0);
            border-radius: 2px;
        }
        
        .timeline-point {
            text-align: center;
            position: relative;
            z-index: 1;
        }
        
        .timeline-dot {
            width: 48px;
            height: 48px;
            background: white;
            border: 4px solid #7B5BA6;
            border-radius: 50%;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        
        .timeline-point:nth-child(1) .timeline-dot { border-color: #5C4080; background: #5C4080; color: white; }
        .timeline-point:nth-child(2) .timeline-dot { border-color: #7B5BA6; }
        .timeline-point:nth-child(3) .timeline-dot { border-color: #9B7BC6; }
        .timeline-point:nth-child(4) .timeline-dot { border-color: #B8A5D3; }
        
        .timeline-age {
            font-size: 18px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 4px;
        }
        
        .timeline-action {
            font-size: 12px;
            color: #5A6A7A;
            max-width: 120px;
            margin: 0 auto;
            line-height: 1.4;
        }
        
        /* CHART 3: Efficacy */
        .efficacy-chart {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        .efficacy-item {
            background: #F9F7FC;
            border-radius: 8px;
            padding: 24px;
            text-align: center;
            border-left: 4px solid #7B5BA6;
        }
        
        .efficacy-number {
            font-size: 48px;
            font-weight: 700;
            color: #5C4080;
            line-height: 1;
            margin-bottom: 8px;
        }
        
        .efficacy-label {
            font-size: 14px;
            color: #2D3E50;
            line-height: 1.4;
        }
        
        .efficacy-source {
            font-size: 11px;
            color: #5A6A7A;
            margin-top: 8px;
        }
        
        /* ==================== 
           QUESTIONS SECTION
           ==================== */
        
        .questions-section {
            padding: 60px;
            background: white;
        }
        
        .questions-section h2 {
            font-size: 28px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 8px;
        }
        
        .questions-section > p {
            font-size: 16px;
            color: #5A6A7A;
            margin-bottom: 32px;
        }
        
        .question-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }
        
        .question-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px 24px;
            background: #F9F7FC;
            border-radius: 4px;
            text-decoration: none;
            color: #1A2530;
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }
        
        .question-item:hover {
            background: white;
            border-left-color: #7B5BA6;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }
        
        .question-icon {
            width: 40px;
            height: 40px;
            background: #E8E0F0;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }
        
        .question-text {
            flex: 1;
        }
        
        .question-text span {
            font-size: 16px;
            font-weight: 500;
        }
        
        .question-text small {
            display: block;
            font-size: 13px;
            color: #5A6A7A;
            margin-top: 4px;
        }
        
        .question-arrow {
            color: #7B5BA6;
            font-size: 18px;
        }
        
        /* ==================== 
           EDITORIAL: SURVIVOR STORIES
           ==================== */
        
        .editorial-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        
        .editorial-photo {
            background: linear-gradient(135deg, #D4C8E5 0%, #E8E0F0 100%);
            min-height: 400px;
            position: relative;
        }
        
        .editorial-content {
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .editorial-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #7B5BA6;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .editorial-content h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 16px;
            line-height: 1.2;
        }
        
        .editorial-quote {
            font-size: 20px;
            color: #2D3E50;
            line-height: 1.6;
            margin-bottom: 24px;
            font-style: italic;
        }
        
        .editorial-attribution {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }
        
        .attribution-avatar {
            width: 48px;
            height: 48px;
            background: #E8E0F0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 600;
            color: #5C4080;
        }
        
        .attribution-text strong {
            display: block;
            font-size: 15px;
            color: #1A2530;
        }
        
        .attribution-text span {
            font-size: 13px;
            color: #5A6A7A;
        }
        
        .editorial-cta {
            color: #5C4080;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        /* ==================== 
           HPV NEXT STEPS TOOL
           ==================== */
        
        .tool-section {
            padding: 60px;
            background: #5C4080;
            color: white;
        }
        
        .tool-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 60px;
            align-items: center;
        }
        
        .tool-section h2 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 16px;
        }
        
        .tool-section h2 em {
            font-style: normal;
            color: #FFEEE5;
        }
        
        .tool-section p {
            font-size: 18px;
            opacity: 0.9;
            margin-bottom: 24px;
            line-height: 1.7;
        }
        
        .tool-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            color: #5C4080;
            padding: 14px 28px;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
        }
        
        .tool-preview {
            background: rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 32px;
        }
        
        .tool-preview-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }
        
        .tool-preview-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        
        .tool-preview-header div strong {
            display: block;
            font-size: 16px;
        }
        
        .tool-preview-header div span {
            font-size: 13px;
            opacity: 0.8;
        }
        
        .process-steps {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        .process-step {
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }
        
        .step-icon {
            width: 32px;
            height: 32px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }
        
        .step-content strong {
            display: block;
            font-size: 14px;
            margin-bottom: 2px;
        }
        
        .step-content span {
            font-size: 13px;
            opacity: 0.8;
        }
        
        /* ==================== 
           ABOUT / FOUNDERS
           ==================== */
        
        .about-section {
            padding: 60px;
            background: #F9F7FC;
        }
        
        .about-header {
            text-align: center;
            max-width: 600px;
            margin: 0 auto 48px;
        }
        
        .about-header h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 12px;
        }
        
        .about-header p {
            font-size: 17px;
            color: #5A6A7A;
            line-height: 1.7;
        }
        
        .founders-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 32px;
            margin-bottom: 48px;
        }
        
        .founder-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            display: grid;
            grid-template-columns: 160px 1fr;
        }
        
        .founder-photo {
            background: linear-gradient(135deg, #D4C8E5, #E8E0F0);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .founder-photo-placeholder {
            width: 100px;
            height: 100px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 700;
            color: #5C4080;
        }
        
        .founder-info {
            padding: 24px;
        }
        
        .founder-name {
            font-size: 20px;
            font-weight: 700;
            color: #1A2530;
            margin-bottom: 4px;
        }
        
        .founder-title {
            font-size: 14px;
            color: #7B5BA6;
            font-weight: 600;
            margin-bottom: 12px;
        }
        
        .founder-bio {
            font-size: 14px;
            color: #5A6A7A;
            line-height: 1.6;
        }
        
        /* Partners */
        .partners-bar {
            background: white;
            border-radius: 8px;
            padding: 24px 32px;
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        .partners-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #5C4080;
            white-space: nowrap;
        }
        
        .partners-logos {
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
            align-items: center;
        }
        
        .partner-logo {
            height: 32px;
            background: #E8E0F0;
            border-radius: 4px;
            padding: 4px 16px;
            display: flex;
            align-items: center;
            font-size: 11px;
            color: #5A6A7A;
            font-weight: 600;
        }
        
        /* ==================== 
           NEWS WITH PHOTOS
           ==================== */
        
        .news-section {
            padding: 60px;
            background: white;
        }
        
        .news-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 32px;
        }
        
        .news-header h2 {
            font-size: 28px;
            font-weight: 700;
            color: #1A2530;
        }
        
        .news-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 24px;
        }
        
        .news-card {
            text-decoration: none;
            color: inherit;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #E8E0F0;
            transition: all 0.2s;
        }
        
        .news-card:hover {
            border-color: #7B5BA6;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }
        
        .news-photo {
            height: 160px;
            background: linear-gradient(135deg, #E8E0F0, #F3EFF8);
            position: relative;
        }
        
        .news-card:nth-child(2) .news-photo {
            background: linear-gradient(135deg, #FDE8DC, #F3EFF8);
        }
        
        .news-card:nth-child(3) .news-photo {
            background: linear-gradient(135deg, #D4C8E5, #E8E0F0);
        }
        
        .news-content {
            padding: 20px;
        }
        
        .news-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
