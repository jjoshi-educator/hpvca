<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPV Cancers Alliance</title>
    <style>
        @page {
            size: 11in 78in;
            margin: 0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background: #FFFFFF;
            color: #1A1A1A;
            width: 11in;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        
        a {
            text-decoration: none;
            color: inherit;
        }
        
        p, h1, h2, h3, blockquote {
            text-wrap: balance;
        }
        
        .utility-bar {
            background: #5C4080;
            padding: 10px 80px;
            display: flex;
            justify-content: flex-end;
            gap: 32px;
            font-size: 13px;
            letter-spacing: 0.01em;
        }
        
        .utility-bar a {
            color: rgba(255,255,255,0.85);
        }
        
        .utility-bar a:hover {
            color: white;
        }
        
        .utility-bar .highlight {
            color: #FFEEE5;
            font-weight: 500;
        }
        
        .header {
            padding: 24px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            border-bottom: 1px solid #E5E5E5;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }
        
        .logo-mark {
            width: 44px;
            height: 44px;
            background: #7B5BA6;
            border-radius: 10px;
            position: relative;
            flex-shrink: 0;
        }
        
        .logo-mark::before {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            border: 2.5px solid white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        
        .logo-text {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 21px;
            font-weight: normal;
            color: #1A1A1A;
            white-space: nowrap;
            letter-spacing: -0.01em;
        }
        
        .logo-text span {
            color: #7B5BA6;
        }
        
        .main-nav {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        .nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: #3D3D3D;
            padding: 8px 0;
            border-bottom: 1.5px solid transparent;
            transition: all 0.2s;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }
        
        .nav-link:hover {
            color: #7B5BA6;
            border-bottom-color: #7B5BA6;
        }
        
        .nav-actions {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: 20px;
            padding-left: 28px;
            border-left: 1px solid #E5E5E5;
        }
        
        .nav-cta {
            background: #7B5BA6;
            color: white;
            padding: 11px 22px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            transition: background 0.2s;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }
        
        .nav-cta:hover {
            background: #5C4080;
        }
        
        .nav-donate {
            color: #7B5BA6;
            font-weight: 500;
            font-size: 14px;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }
        
        .nav-donate:hover {
            color: #5C4080;
        }
        
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 620px;
        }
        
        .hero-content {
            padding: 100px 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #FAFAF9;
        }
        
        .hero-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #7B5BA6;
            margin-bottom: 28px;
        }
        
        .hero h1 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 50px;
            font-weight: normal;
            line-height: 1.12;
            color: #1A1A1A;
            margin-bottom: 28px;
            letter-spacing: -0.025em;
            max-width: 500px;
        }
        
        .hero h1 em {
            font-style: italic;
            color: #5C4080;
        }
        
        .hero-lead {
            font-size: 18px;
            line-height: 1.75;
            color: #4A4A4A;
            margin-bottom: 40px;
            max-width: 420px;
            letter-spacing: 0.005em;
        }
        
        .hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: #7B5BA6;
            color: white;
            padding: 18px 32px;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 500;
            transition: background 0.2s;
            width: fit-content;
            letter-spacing: 0.01em;
        }
        
        .hero-cta:hover {
            background: #5C4080;
        }
        
        .hero-cta svg {
            width: 18px;
            height: 18px;
        }
        
        .hero-secondary {
            margin-top: 24px;
            color: #7B5BA6;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.01em;
        }
        
        .hero-secondary:hover {
            text-decoration: underline;
        }
        
        .hero-image {
            background: linear-gradient(155deg, #E8E0F0 0%, #D4C8E5 100%);
        }
        
        .impact-bar {
            background: #5C4080;
            padding: 64px 80px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 32px;
        }
        
        .impact-stat {
            text-align: center;
            color: white;
            padding: 0 16px;
        }
        
        .impact-number {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 56px;
            font-weight: normal;
            line-height: 1;
            margin-bottom: 14px;
            letter-spacing: -0.03em;
        }
        
        .impact-unit {
            font-size: 32px;
            opacity: 0.8;
        }
        
        .impact-label {
            font-size: 14px;
            font-weight: 400;
            opacity: 0.85;
            line-height: 1.55;
            letter-spacing: 0.01em;
        }
        
        .mission {
            padding: 120px 80px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }
        
        .mission-content {
            max-width: 440px;
        }
        
        .section-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #7B5BA6;
            margin-bottom: 24px;
        }
        
        .mission h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 44px;
            font-weight: normal;
            line-height: 1.15;
            color: #1A1A1A;
            margin-bottom: 28px;
            letter-spacing: -0.02em;
        }
        
        .mission p {
            font-size: 17px;
            line-height: 1.8;
            color: #4A4A4A;
            margin-bottom: 20px;
            letter-spacing: 0.005em;
        }
        
        .mission-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #7B5BA6;
            font-size: 14px;
            font-weight: 500;
            margin-top: 16px;
            transition: gap 0.2s;
            letter-spacing: 0.01em;
        }
        
        .mission-link:hover {
            gap: 12px;
        }
        
        .mission-image {
            background: linear-gradient(145deg, #E8E0F0 0%, #F3EFF8 100%);
            border-radius: 12px;
            height: 460px;
        }
        
        .info-section {
            background: #FAFAF9;
            padding: 120px 80px;
        }
        
        .info-header {
            max-width: 540px;
            margin-bottom: 72px;
        }
        
        .info-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 44px;
            font-weight: normal;
            line-height: 1.15;
            color: #1A1A1A;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        .info-header p {
            font-size: 17px;
            line-height: 1.8;
            color: #4A4A4A;
            letter-spacing: 0.005em;
        }
        
        .cancer-visualization {
            margin-bottom: 72px;
        }
        
        .cancer-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 20px;
        }
        
        .cancer-card {
            background: white;
            border-radius: 10px;
            padding: 32px 20px 28px;
            text-align: center;
            border: 1px solid #E8E8E8;
            transition: all 0.25s;
        }
        
        .cancer-card:hover {
            border-color: #7B5BA6;
            box-shadow: 0 12px 40px rgba(123, 91, 166, 0.1);
            transform: translateY(-4px);
        }
        
        .cancer-bar-container {
            height: 88px;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            margin-bottom: 24px;
        }
        
        .cancer-bar {
            width: 6px;
            background: linear-gradient(180deg, #9B7BC6 0%, #5C4080 100%);
            border-radius: 3px;
        }
        
        .cancer-card:nth-child(1) .cancer-bar { height: 80px; }
        .cancer-card:nth-child(2) .cancer-bar { height: 72px; }
        .cancer-card:nth-child(3) .cancer-bar { height: 48px; }
        .cancer-card:nth-child(4) .cancer-bar { height: 32px; }
        .cancer-card:nth-child(5) .cancer-bar { height: 20px; }
        .cancer-card:nth-child(6) .cancer-bar { height: 16px; }
        
        .cancer-name {
            font-size: 14px;
            font-weight: 600;
            color: #1A1A1A;
            margin-bottom: 6px;
            letter-spacing: 0.01em;
        }
        
        .cancer-stat {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 14px;
            color: #7B5BA6;
            font-style: italic;
        }
        
        .cancer-caption {
            text-align: center;
            margin-top: 24px;
            font-size: 13px;
            color: #777;
            font-style: italic;
            letter-spacing: 0.01em;
        }
        
        .info-narrative {
            background: white;
            border-radius: 10px;
            padding: 56px 64px;
            border-left: 4px solid #7B5BA6;
        }
        
        .info-narrative p {
            font-size: 19px;
            line-height: 1.9;
            color: #2D2D2D;
            max-width: 700px;
            letter-spacing: 0.005em;
        }
        
        .info-narrative .stat {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 24px;
            font-weight: normal;
            color: #5C4080;
        }
        
        .info-source {
            margin-top: 24px;
            font-size: 12px;
            color: #999;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }
        
        .questions-section {
            padding: 120px 80px;
            background: white;
        }
        
        .questions-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 56px;
        }
        
        .questions-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 40px;
            font-weight: normal;
            color: #1A1A1A;
            letter-spacing: -0.015em;
        }
        
        .questions-header a {
            color: #7B5BA6;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.01em;
        }
        
        .questions-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
        
        .question-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 26px 32px;
            background: #FAFAF9;
            border-radius: 8px;
            border: 1px solid transparent;
            transition: all 0.2s;
        }
        
        .question-card:hover {
            background: white;
            border-color: #7B5BA6;
            box-shadow: 0 6px 24px rgba(123, 91, 166, 0.1);
        }
        
        .question-text {
            font-size: 16px;
            font-weight: 500;
            color: #1A1A1A;
            letter-spacing: 0.005em;
        }
        
        .question-arrow {
            color: #7B5BA6;
            font-size: 20px;
            transition: transform 0.2s;
            font-weight: 300;
        }
        
        .question-card:hover .question-arrow {
            transform: translateX(4px);
        }
        
        .tool-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        
        .tool-content {
            background: #5C4080;
            padding: 100px 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
        }
        
        .tool-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.65);
            margin-bottom: 24px;
        }
        
        .tool-content h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 44px;
            font-weight: normal;
            line-height: 1.15;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        .tool-content h2 em {
            font-style: italic;
            color: #FFEEE5;
        }
        
        .tool-content > p {
            font-size: 17px;
            line-height: 1.75;
            opacity: 0.9;
            margin-bottom: 40px;
            max-width: 380px;
            letter-spacing: 0.01em;
        }
        
        .tool-cta {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: white;
            color: #5C4080;
            padding: 18px 32px;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 500;
            width: fit-content;
            transition: all 0.2s;
            letter-spacing: 0.01em;
        }
        
        .tool-cta:hover {
            background: #FFEEE5;
        }
        
        .tool-visual {
            background: linear-gradient(145deg, #7B5BA6 0%, #9B7BC6 100%);
            padding: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .tool-preview {
            background: rgba(255,255,255,0.12);
            border-radius: 16px;
            padding: 44px;
            width: 100%;
            max-width: 340px;
            border: 1px solid rgba(255,255,255,0.18);
        }
        
        .tool-preview-header {
            text-align: center;
            padding-bottom: 28px;
            border-bottom: 1px solid rgba(255,255,255,0.18);
            margin-bottom: 32px;
            color: white;
        }
        
        .tool-preview-header strong {
            display: block;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 22px;
            font-weight: normal;
            margin-bottom: 8px;
            letter-spacing: -0.01em;
        }
        
        .tool-preview-header span {
            font-size: 13px;
            opacity: 0.75;
            letter-spacing: 0.02em;
        }
        
        .tool-steps {
            color: white;
        }
        
        .tool-step {
            display: flex;
            gap: 18px;
            margin-bottom: 24px;
        }
        
        .tool-step:last-child {
            margin-bottom: 0;
        }
        
        .step-num {
            width: 32px;
            height: 32px;
            background: rgba(255,255,255,0.18);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            flex-shrink: 0;
        }
        
        .step-text {
            font-size: 14px;
            line-height: 1.6;
            padding-top: 6px;
            opacity: 0.9;
            letter-spacing: 0.01em;
        }
        
        .story-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        
        .story-image {
            background: linear-gradient(155deg, #D4C8E5 0%, #E8E0F0 100%);
            min-height: 560px;
        }
        
        .story-content {
            padding: 100px 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #FAFAF9;
        }
        
        .story-content .section-eyebrow {
            color: #C97A4A;
        }
        
        .story-quote {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 32px;
            font-weight: normal;
            line-height: 1.45;
            color: #1A1A1A;
            margin-bottom: 40px;
            letter-spacing: -0.015em;
            font-style: italic;
            max-width: 420px;
        }
        
        .story-attribution {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-bottom: 32px;
        }
        
        .attribution-avatar {
            width: 60px;
            height: 60px;
            background: #E8E0F0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 20px;
            font-weight: normal;
            color: #5C4080;
        }
        
        .attribution-info strong {
            display: block;
            font-size: 17px;
            font-weight: 600;
            color: #1A1A1A;
            margin-bottom: 4px;
            letter-spacing: 0.005em;
        }
        
        .attribution-info span {
            font-size: 14px;
            color: #777;
            letter-spacing: 0.01em;
        }
        
        .story-link {
            color: #7B5BA6;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.01em;
        }
        
        .story-link:hover {
            text-decoration: underline;
        }
        
        .founders-section {
            padding: 120px 80px;
            background: white;
        }
        
        .founders-header {
            text-align: center;
            max-width: 500px;
            margin: 0 auto 72px;
        }
        
        .founders-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 44px;
            font-weight: normal;
            line-height: 1.15;
            color: #1A1A1A;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        .founders-header p {
            font-size: 17px;
            line-height: 1.75;
            color: #4A4A4A;
            letter-spacing: 0.005em;
        }
        
        .founders-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 36px;
            margin-bottom: 72px;
        }
        
        .founder-card {
            display: grid;
            grid-template-columns: 180px 1fr;
            background: #FAFAF9;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .founder-image {
            background: linear-gradient(155deg, #D4C8E5 0%, #E8E0F0 100%);
        }
        
        .founder-info {
            padding: 40px;
        }
        
        .founder-name {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 24px;
            font-weight: normal;
            color: #1A1A1A;
            margin-bottom: 6px;
            letter-spacing: -0.01em;
        }
        
        .founder-title {
            font-size: 12px;
            font-weight: 600;
            color: #7B5BA6;
            margin-bottom: 20px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }
        
        .founder-bio {
            font-size: 15px;
            line-height: 1.7;
            color: #4A4A4A;
            letter-spacing: 0.005em;
        }
        
        .partners-section {
            background: #FAFAF9;
            border-radius: 10px;
            padding: 36px 48px;
            display: flex;
            align-items: flex-start;
            gap: 48px;
        }
        
        .partners-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #7B5BA6;
            white-space: nowrap;
            padding-top: 4px;
        }
        
        .partners-list {
            font-size: 15px;
            color: #4A4A4A;
            line-height: 1.8;
            letter-spacing: 0.005em;
        }
        
        .news-section {
            padding: 120px 80px;
            background: #FAFAF9;
        }
        
        .news-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 56px;
        }
        
        .news-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 40px;
            font-weight: normal;
            color: #1A1A1A;
            letter-spacing: -0.015em;
        }
        
        .news-header a {
            color: #7B5BA6;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.01em;
        }
        
        .news-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
        }
        
        .news-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #E8E8E8;
            transition: all 0.25s;
        }
        
        .news-card:hover {
            border-color: #7B5BA6;
            box-shadow: 0 16px 48px rgba(0,0,0,0.08);
            transform: translateY(-4px);
        }
        
        .news-image {
            height: 200px;
            background: linear-gradient(145deg, #E8E0F0 0%, #F3EFF8 100%);
        }
        
        .news-card:nth-child(2) .news-image {
            background: linear-gradient(145deg, #FDE8DC 0%, #F3EFF8 100%);
        }
        
        .news-card:nth-child(3) .news-image {
            background: linear-gradient(145deg, #D4C8E5 0%, #E8E0F0 100%);
        }
        
        .news-content {
            padding: 32px;
        }
        
        .news-tag {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #7B5BA6;
            margin-bottom: 14px;
        }
        
        .news-card h3 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 22px;
            font-weight: normal;
            color: #1A1A1A;
            line-height: 1.3;
            margin-bottom: 12px;
            letter-spacing: -0.01em;
        }
        
